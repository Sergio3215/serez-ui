// renderer_gui.sz — Renderer GUI (píxeles) para serez-ui
//
// Recorre el árbol VNode y lo dibuja en una ventana real vía el namespace `Gui`
// del core. Layout de flujo: por defecto vertical (un nodo debajo de otro); el
// contenedor Row coloca sus hijos lado a lado, cada uno a su ancho de contenido.
//
// FOCO UNIFICADO: cada elemento interactivo (Button/Input/Select/Checkbox/
// Textarea/RadioGroup/Slider/Dropdown/Link) recibe un índice de foco según su
// orden de render. `this.focus` marca cuál está enfocado; el renderer le dibuja
// un anillo. El GuiEventLoop (window.sz) navega con Tab/clic y dirige el teclado
// al enfocado. ProgressBar/Label no son enfocables.
//
// El texto es bitmap 8x8 escalado (Gui.drawText), monoespaciado: 8*scale px por
// carácter — eso permite posicionar el cursor y recortar texto largo con exactitud.

use permissions { Gui }

export public class GuiRenderer {
    public GuiRenderer() {
        this.pad        = 20
        this.cx         = 20     // x actual del flujo (cambia dentro de Row)
        this.cy         = 0      // y actual del flujo
        this.w          = 640
        this.h          = 480    // alto vivo de la ventana (para condiciones .szs por height)
        this.colWidth   = 600    // ancho disponible para el nodo actual
        this.lastW      = 0      // ancho que ocupó el último nodo (lo lee Row)
        this.minW       = 0      // min-width del contenido (0 = sin límite)
        this.maxW       = 0      // max-width del contenido (0 = sin límite)
        this.regions    = []
        this.focusOrd   = 0      // contador de enfocables durante el render
        this.focus      = 0      // índice del enfocable activo
        this.caret      = 0      // posición del cursor en el campo de texto enfocado
        this.selAnchor  = -1     // otro extremo de la selección (-1 = sin selección)
        this.mouseX     = -1
        this.mouseY     = -1
        this.mouseHeld  = false
        this.sheet      = null   // Stylesheet (.szs) opcional
        this.ctx        = []     // contexto de estado [[nombre, valor]] para condiciones
        this.fullCtx    = []     // ctx + width/height inyectados (media queries .szs)
        this.scrollY    = 0      // desplazamiento vertical del scroll (px)
        this.contentH   = 0      // alto total del contenido del último render (px)
        this.drewCaret  = false  // ¿el último render dibujó un caret de texto?
        this.winFocused = true   // ¿la VENTANA tiene foco del SO? (Gui.focused) — sin foco no se anima el caret
        this.imePreedit = ""     // composición IME en curso (Gui.imePreedit), "" si no hay
        this.filesHovering = false // ¿hay archivos arrastrándose sobre la ventana? (Gui.hoveredFiles) — resalta DropZone

        // ── Camino de render NATIVO (Fase 3, detrás de flag) ──
        // Cuando native=true, render() baja el VDOM a primitivos y delega el
        // layout+CSS+paint al core (Gui.renderTree) en vez del walk interpretado.
        // El intérprete queda como referencia de QA. Default off = sin cambios.
        this.native    = false
        this.coreSheet = -1      // handle de Gui.loadStylesheet (cacheado, 1-based; -1 = sin cargar)

        // Scrollbar de la ventana: métricas para hit-test en window.sz.
        this.sbVisible  = false  // ¿la scrollbar se dibujó en el último render?
        this.sbTrackX   = 0      // borde izquierdo del track (px)
        this.sbTrackW   = 14     // ancho del track (px)
        this.sbThumbY   = 0      // posición Y del thumb (px)
        this.sbThumbH   = 0      // alto del thumb (px)
        this.sbMaxS     = 0      // scroll máximo (px)

        // Textarea scroll interno: cada Textarea (por focusOrd) puede tener su
        // propio desplazamiento vertical independiente del scroll de la ventana.
        this.taScrollOrd = []    // focusOrd de cada Textarea registrado
        this.taScrollY   = []    // scrollY interno de cada Textarea registrado
        this.taLastCarOrd= []    // focusOrd para el tracking del caret
        this.taLastCarVal= []    // última posición del caret (evita snap-back del scroll)
        this.taHoverIdx  = -1    // índice en regions del Textarea bajo el mouse (-1 = ninguno)

        // Caché de segmentos de Textarea: evita re-segmentar O(n) en cada frame
        // cuando el valor y el ancho no cambiaron (clave para respuestas grandes).
        this.taSegCacheOrd   = []   // focusOrd
        this.taSegCacheVal   = []   // último valor (string) cacheado
        this.taSegCacheCols  = []   // último maxCols cacheado
        this.taSegCacheStart = []   // segStart[] cacheado
        this.taSegCacheText  = []   // segText[] cacheado
        this.taSegCacheLen   = []   // length() del valor cacheado (rechazo O(1) antes del compare)
        this.vdomDirty       = true // ¿el vdom cambió desde el último render? lo fija window.sz.
                                    // En scroll/blink el vdom es idéntico → reusar segmentos sin
                                    // comparar el string entero (evita O(n) por frame en respuestas grandes).
        this.fontsReady     = false  // ¿ya se cargaron las fuentes :font de la hoja?
        this.fontAliasNames = []     // alias declarados en :font
        this.fontRealNames  = []     // nombre real de familia que devolvió Gui.loadFont
        // Tipografía por defecto (moderna) cuando la app NO define font-family en .szs.
        // El .szs de la app tiene precedencia (famFor la consulta primero). Fuentes de
        // sistema (no requieren :font); si no existen, Gui.setFont devuelve false y se cae
        // a la rejilla monoespaciada del core (sin romper).
        this.defaultFam  = "Segoe UI"        // proporcional para texto de bloque y controles
        this.defaultMono = "Cascadia Mono"   // monoespaciada moderna para Input/Textarea (caret uniforme)
        this.defaultMonoAlt = "Consolas"     // fallback si Cascadia Mono no está instalada

        // Caché de resolución de estilos: resolveProp/colorProp son O(selectores×decls)
        // POR llamada, y se invocan por cada propiedad de cada widget POR frame (el cuello
        // del render). Cachear por (tag|prop) baja el render de ~decenas de ms a ~pocos ms.
        // Se invalida cuando cambia la firma del ctx (width/height/styleVars → media queries).
        this.styleSig       = "?" // firma del fullCtx del último refresh
        this.cacheTagNames  = []  // tags resueltos (paralelo a Start/End)
        this.cacheTagStart  = []  // rango [start,end) del tag en los arrays flat
        this.cacheTagEnd    = []
        this.cacheFlatProps = []  // props de TODOS los tags concatenadas (FLAT → sin copias por value-sem)
        this.cacheFlatVals  = []
        this.lastStyleTag   = "?" // fast-path: último tag consultado (lookups consecutivos del mismo widget)
        this.lastStyleIdx   = -1

        // Dropdown abierto (overlay diferido, dibujado encima al final)
        this.dropOpen     = false
        this.dropHi       = 0
        this.hasOpenDrop  = false
        this.openDropX    = 0
        this.openDropY    = 0
        this.openDropW    = 0
        this.openDropH    = 0
        this.openDropNode = null

        // Caché de imágenes: ruta → handle de Gui.loadImage (cargar una sola vez).
        this.imgPaths   = []
        this.imgHandles = []

        // Modal diferido (scrim + caja, dibujado al final, captura clics).
        this.hasModal       = false
        this.modalNode      = null
        this.modalRegStart  = 0   // primer índice de region que pertenece al modal
        this.modalBoxX      = 0   // rect de la caja (para distinguir clic en scrim vs caja)
        this.modalBoxY      = 0
        this.modalBoxW      = 0
        this.modalBoxH      = 0

        // Tooltip diferido (cajita junto al mouse al hacer hover).
        this.hasTip = false
        this.tipText = ""
        this.tipX = 0
        this.tipY = 0

        // Tema (oscuro)
        this.colBg     = 0x0f172a
        this.colText   = 0xe2e8f0
        this.colMuted  = 0x94a3b8
        this.colBtn    = 0x3b82f6
        this.colBtnHov = 0x60a5fa
        this.colBtnDn  = 0x1d4ed8
        this.colInput  = 0x111827
        this.colBorder = 0x334155
        this.colFocus  = 0x60a5fa
        this.colLink   = 0x60a5fa

        // Retained-mode: el render emite nodos de escena con reuso por
        // posición (métodos sw* de ESTA clase — un writer-objeto aparte no
        // funciona: this.obj.metodo() muta una copia por semántica de valor).
        // window.sz presenta con Gui.renderScene(this.bgColor()).
        this.swIds  = []    // id de nodo del core por posición
        this.swSigs = []    // firma (tipo|valores) por posición
        this.swPos  = 0
        this.swFont = ""    // familia activa (se estampa en los nodos de texto)
        this.bgCol  = 0x0f172a
    }

    // Color de fondo del último render — window.sz lo pasa a Gui.renderScene.
    public int bgColor() { return this.bgCol }

    // ── Retained-mode: emisión de nodos con reuso por posición ────────────────
    // El render emite sus primitivas en el mismo orden cada frame; si la
    // posición k tiene la misma firma (tipo+valores) que el frame anterior, NO
    // se llama a Gui (0 costo). Si cambió, se borra el nodo viejo y se crea el
    // nuevo con z = posición (el core dibuja por (z, id) → z posicional = orden
    // de emisión, exactamente como el modo inmediato). Un frame sin cambios se
    // reduce a Gui.renderScene(), que además salta el rasterizado (dirty-skip).

    public void swBegin() {
        this.swPos = 0
    }

    // Borra los nodos sobrantes de frames anteriores (el árbol se encogió).
    public void swEnd() {
        while (this.swIds.length() > this.swPos) {
            Gui.nodeDelete(this.swIds[this.swIds.length() - 1])
            this.swIds.pop()
            this.swSigs.pop()
        }
    }

    // Fuente activa: afecta a los nodos de texto que se emitan Y a
    // Gui.measureText (por eso también se aplica al estado inmediato del core).
    public bool swSetFont(string family) {
        let ok = Gui.setFont(family)
        if (ok) { this.swFont = family }
        if (family == "") { this.swFont = "" }
        return ok
    }

    // ¿La posición actual ya tiene EXACTAMENTE este nodo? (avanza si sí)
    public bool swHit(string sig) {
        let k = this.swPos
        if (k < this.swIds.length()) {
            if (this.swSigs[k] == sig) {
                this.swPos = k + 1
                return true
            }
            Gui.nodeDelete(this.swIds[k])   // distinto: fuera el viejo
        }
        return false
    }

    // Registra el nodo recién creado en la posición actual (z = posición).
    public void swPut(int nid, string sig) {
        let k = this.swPos
        Gui.nodeSet(nid, "z", k)
        if (k < this.swIds.length()) {
            this.swIds[k] = nid
            this.swSigs[k] = sig
        } else {
            this.swIds.push(nid)
            this.swSigs.push(sig)
        }
        this.swPos = k + 1
    }

    public void swRect(int x, int y, int w2, int h2, int c) {
        let sig = "r|" + x + "|" + y + "|" + w2 + "|" + h2 + "|" + c
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeRect(x, y, w2, h2, c), sig)
    }

    public void swRoundRect(int x, int y, int w2, int h2, int rad, int c) {
        let sig = "rr|" + x + "|" + y + "|" + w2 + "|" + h2 + "|" + rad + "|" + c
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeRoundRect(x, y, w2, h2, rad, c), sig)
    }

    public void swRectAlpha(int x, int y, int w2, int h2, int c, int a) {
        let sig = "ra|" + x + "|" + y + "|" + w2 + "|" + h2 + "|" + c + "|" + a
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeRectAlpha(x, y, w2, h2, c, a), sig)
    }

    public void swRectOutline(int x, int y, int w2, int h2, int c) {
        let sig = "ro|" + x + "|" + y + "|" + w2 + "|" + h2 + "|" + c
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeRectOutline(x, y, w2, h2, c), sig)
    }

    public void swCircle(int x, int y, int rad, int c) {
        let sig = "c|" + x + "|" + y + "|" + rad + "|" + c
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeCircle(x, y, rad, c), sig)
    }

    public void swLine(int x1, int y1, int x2, int y2, int c) {
        let sig = "l|" + x1 + "|" + y1 + "|" + x2 + "|" + y2 + "|" + c
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeLine(x1, y1, x2, y2, c), sig)
    }

    public void swText(int x, int y, string t, int sc, int c, int style = 0, int spacing = 0) {
        let sig = "t|" + x + "|" + y + "|" + sc + "|" + c + "|" + style + "|" + spacing + "|" + this.swFont + "|" + t
        if (this.swHit(sig)) { return; }
        let nid = Gui.nodeText(x, y, t, sc, c)
        if (style != 0) { Gui.nodeSet(nid, "style", style) }
        if (spacing != 0) { Gui.nodeSet(nid, "spacing", spacing) }
        if (this.swFont != "") { Gui.nodeSet(nid, "font", this.swFont) }
        this.swPut(nid, sig)
    }

    public void swImage(int x, int y, int handle) {
        let sig = "i|" + x + "|" + y + "|" + handle
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeImage(x, y, handle), sig)
    }

    public void swPolygon(any pts, int c) {
        let sig = "pg|" + c + "|" + this.swPtsSig(pts)
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodePolygon(pts, c), sig)
    }

    public void swPolyline(any pts, int wd, int c) {
        let sig = "pl|" + wd + "|" + c + "|" + this.swPtsSig(pts)
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodePolyline(pts, wd, c), sig)
    }

    public void swClipPush(int x, int y, int w2, int h2) {
        let sig = "cp|" + x + "|" + y + "|" + w2 + "|" + h2
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeClipPush(x, y, w2, h2), sig)
    }

    public void swClipPop() {
        let sig = "cq"
        if (this.swHit(sig)) { return; }
        this.swPut(Gui.nodeClipPop(), sig)
    }

    public string swPtsSig(any pts) {
        let s = ""
        let i = 0
        while (i < pts.length()) {
            s = s + pts[i] + ","
            i = i + 1
        }
        return s
    }

    public void setMouse(int x, int y, bool held) {
        this.mouseX    = x
        this.mouseY    = y
        this.mouseHeld = held
    }

    public void setFocus(int idx)      { this.focus = idx }
    public void setCaret(int c)        { this.caret = c }
    public void setSel(int a)          { this.selAnchor = a }
    public void setDropOpen(bool b)    { this.dropOpen = b }
    public void setDropHi(int i)       { this.dropHi = i }
    public void setWidthBounds(int mn, int mx) { this.minW = mn; this.maxW = mx }
    // window.sz lo fija antes de cada render: true si el vdom se reconstruyó (cambio
    // de estado/resize), false si es un re-rasterizado puro (scroll/blink) donde los
    // valores son idénticos al frame anterior → el caché de segmentos es válido sin comparar.
    public void setVdomDirty(bool d) { this.vdomDirty = d }

    // Foco del SO de la ventana (Gui.focused). Sin foco, los campos no dibujan caret
    // (ni lo animan): un Input enfocado de una ventana en segundo plano no parpadea.
    public void setWinFocused(bool b) { this.winFocused = b }
    // Composición IME en curso (Gui.imePreedit). Se pinta subrayada tras el caret.
    public void setImePreedit(string s) { this.imePreedit = s }
    // ¿Hay archivos arrastrándose sobre la ventana? (Gui.hoveredFiles) — resalta DropZone.
    public void setFilesHovering(bool b) { this.filesHovering = b }

    // ¿El último render dibujó un caret de texto (Input/Textarea enfocado Y ventana
    // enfocada)? El loop lo usa para animar el parpadeo SOLO cuando hace falta.
    public bool caretActive() { return this.drewCaret }

    // Ajusta el scroll vertical con la rueda (dy = delta de Gui.scroll()). Acota a [0, max].
    public void scrollBy(int dy) {
        this.scrollY = this.scrollY - dy * 40
        let maxS = this.contentH + this.pad - this.h
        if (maxS < 0) { maxS = 0; }
        if (this.scrollY > maxS) { this.scrollY = maxS; }
        if (this.scrollY < 0) { this.scrollY = 0; }
    }

    // Fija el scroll a una posición proporcional [0..1] (para click en scrollbar).
    public void scrollTo(int posY) {
        let maxS = this.contentH + this.pad - this.h
        if (maxS < 1) { maxS = 1; }
        // posY es la Y del click en la ventana → convertir a ratio sobre el track.
        let ratio = posY
        if (ratio < 0) { ratio = 0; }
        if (ratio > this.h) { ratio = this.h; }
        this.scrollY = (ratio * maxS) / this.h
        if (this.scrollY > maxS) { this.scrollY = maxS; }
        if (this.scrollY < 0) { this.scrollY = 0; }
    }

    // ¿El punto (mx, my) está sobre la scrollbar de la ventana?
    public bool scrollbarHit(int mx, int my) {
        if (!this.sbVisible) { return false; }
        return mx >= this.sbTrackX && mx < this.sbTrackX + this.sbTrackW && my >= 0 && my < this.h
    }

    // Scroll interno de un Textarea (por su focusOrd). Devuelve el startSeg.
    public int getTaScroll(int ord) {
        let i = 0
        while (i < this.taScrollOrd.length()) {
            if (this.taScrollOrd[i] == ord) { return this.taScrollY[i]; }
            i = i + 1
        }
        return 0
    }
    public void setTaScroll(int ord, int val) {
        let i = 0
        while (i < this.taScrollOrd.length()) {
            if (this.taScrollOrd[i] == ord) {
                this.taScrollY[i] = val;
                return;
            }
            i = i + 1
        }
        this.taScrollOrd.push(ord)
        this.taScrollY.push(val)
    }

    // Tracking del último caret por Textarea (para no forzar scroll salvo que se mueva).
    public int getTaLastCar(int ord) {
        let i = 0
        while (i < this.taLastCarOrd.length()) {
            if (this.taLastCarOrd[i] == ord) { return this.taLastCarVal[i]; }
            i = i + 1
        }
        return -1
    }
    public void setTaLastCar(int ord, int val) {
        let i = 0
        while (i < this.taLastCarOrd.length()) {
            if (this.taLastCarOrd[i] == ord) { this.taLastCarVal[i] = val; return; }
            i = i + 1
        }
        this.taLastCarOrd.push(ord)
        this.taLastCarVal.push(val)
    }

    // Scroll con rueda del mouse sobre un Textarea. dy = delta de Gui.scroll().
    // Devuelve true si consumió el scroll (hay un Textarea bajo el mouse).
    public bool scrollTaByWheel(int dy) {
        if (this.taHoverIdx < 0) { return false; }
        let rg = this.regions[this.taHoverIdx]
        let node = rg[5]
        // Necesitamos el total de segmentos y visRows para acotar. Los guardamos
        // como campos extra en la region: [tag, x, y, w, h, node, taOrd, taTotalSegs, taVisRows]
        if (rg.length() < 9) { return false; }
        let taOrd      = rg[6]
        let totalSegs  = rg[7]
        let visRows    = rg[8]
        let maxStart   = totalSegs - visRows
        if (maxStart < 0) { maxStart = 0; }
        let cur = this.getTaScroll(taOrd)
        let step = 3    // líneas por notch de rueda
        cur = cur - dy * step
        if (cur < 0) { cur = 0; }
        if (cur > maxStart) { cur = maxStart; }
        this.setTaScroll(taOrd, cur)
        return true
    }

    // Alto del thumb de la barra de un Textarea (proporción visible), con las MISMAS
    // fórmulas que drawTaScrollbarsNative para que el dibujo y el arrastre coincidan.
    public int taThumbH(int bh, int total, int vis) {
        let th = (bh * vis) / total
        if (th < 24) { th = 24; }
        if (th > bh) { th = bh; }
        return th
    }

    // Offset con el que se agarró el thumb al hacer click: si el click cae SOBRE el
    // thumb, la distancia desde su borde superior (arrastre relativo, sin salto); si
    // cae en el track (fuera del thumb), se centra el thumb en el cursor.
    public int taGrabOffset(any rg, int my) {
        if (rg.length() < 9) { return 0; }
        let by = rg[2]; let bh = rg[4]
        let total = rg[7]; let vis = rg[8]
        let maxSt = total - vis
        if (maxSt < 1) { return 0; }
        let thumbH = this.taThumbH(bh, total, vis)
        let range = bh - thumbH
        if (range < 1) { range = 1; }
        let pos = this.getTaScroll(rg[6])
        if (pos < 0) { pos = 0; }
        if (pos > maxSt) { pos = maxSt; }
        let thumbTop = by + (pos * range) / maxSt
        if (my >= thumbTop && my < thumbTop + thumbH) { return my - thumbTop; }
        return thumbH / 2
    }

    // Scroll de un Textarea arrastrando su barra interna. `grabOffset` = dónde se
    // agarró el thumb (de taGrabOffset) → el borde superior del thumb sigue a
    // `my - grabOffset`, así el arrastre es 1:1 con el cursor (sin salto). Usa las
    // MISMAS métricas que el thumb dibujado, por eso el clic es preciso.
    public void scrollToTa(any rg, int my, int grabOffset) {
        if (rg.length() < 9) { return; }
        let by = rg[2]; let bh = rg[4]
        let taOrd = rg[6]; let total = rg[7]; let vis = rg[8]
        let maxSt = total - vis
        if (maxSt < 1) { return; }
        let thumbH = this.taThumbH(bh, total, vis)
        let range = bh - thumbH
        if (range < 1) { range = 1; }
        let rel = my - grabOffset - by
        if (rel < 0) { rel = 0; }
        if (rel > range) { rel = range; }
        this.setTaScroll(taOrd, (rel * maxSt) / range)
    }

    // Scroll de un Textarea por teclado (flechas/PageUp-Down): mueve `delta` líneas
    // el textarea de la region `idx`. Devuelve true si cambió.
    public bool scrollTaByLines(int idx, int delta) {
        if (idx < 0 || idx >= this.regions.length()) { return false; }
        let rg = this.regions[idx]
        if (rg.length() < 9) { return false; }
        let taOrd = rg[6]; let total = rg[7]; let vis = rg[8]
        let maxSt = total - vis
        if (maxSt < 0) { maxSt = 0; }
        let cur = this.getTaScroll(taOrd)
        let nv = cur + delta
        if (nv < 0) { nv = 0; }
        if (nv > maxSt) { nv = maxSt; }
        if (nv == cur) { return false; }
        this.setTaScroll(taOrd, nv)
        return true
    }

    // Índice de region del Textarea (con scroll) bajo el punto (mx,my), o -1.
    public int taRegionAt(int mx, int my) {
        let i = 0
        while (i < this.regions.length()) {
            let rg = this.regions[i]
            if (rg.length() > 8 && rg[7] > rg[8]) {
                if (mx >= rg[1] && mx < rg[1] + rg[3] && my >= rg[2] && my < rg[2] + rg[4]) { return i; }
            }
            i = i + 1
        }
        return -1
    }

    // Asigna la hoja de estilos (.szs) y el contexto de estado para condiciones.
    public void setStyles(any sheet, any ctx) {
        this.sheet = sheet
        this.ctx   = ctx
    }

    // Activa/desactiva el camino de render nativo (Fase 3).
    public void setNative(bool b) { this.native = b }

    // Color de una prop CSS para un tag, o el fallback si no hay hoja/regla.
    // Invalida la caché de estilos si cambió la firma del ctx (width/height/styleVars).
    // Llamado al inicio de cada render(), tras armar fullCtx.
    public void refreshStyleCache() {
        let sig = ""
        let i = 0
        while (i < this.fullCtx.length()) {
            sig = sig + this.fullCtx[i][0] + "=" + ("" + this.fullCtx[i][1]) + ";"
            i = i + 1
        }
        if (sig != this.styleSig) {
            this.styleSig       = sig
            this.cacheTagNames  = []
            this.cacheTagStart  = []
            this.cacheTagEnd    = []
            this.cacheFlatProps = []
            this.cacheFlatVals  = []
            this.lastStyleTag   = "?"
            this.lastStyleIdx   = -1
        }
    }

    // Valor crudo (string|null) de (tag, prop). Cachea por tag en arrays FLAT (sin
    // copias por value-semantics) + fast-path del último tag. La 1ra prop de un tag
    // resuelve TODAS sus props de una (un escaneo), el resto del frame son lecturas flat.
    public any styleRaw(string tag, string prop) {
        let idx = -1
        if (tag == this.lastStyleTag) {
            idx = this.lastStyleIdx
        } else {
            let i = 0
            while (i < this.cacheTagNames.length()) {
                if (this.cacheTagNames[i] == tag) { idx = i; i = this.cacheTagNames.length() } else { i = i + 1 }
            }
            if (idx < 0) {
                let rec = this.sheet.allPropsForTag(tag, this.fullCtx)
                let p = rec[0]
                let v = rec[1]
                let start = this.cacheFlatProps.length()
                let j = 0
                while (j < p.length()) {
                    this.cacheFlatProps.push(p[j])
                    this.cacheFlatVals.push(v[j])
                    j = j + 1
                }
                this.cacheTagNames.push(tag)
                this.cacheTagStart.push(start)
                this.cacheTagEnd.push(this.cacheFlatProps.length())
                idx = this.cacheTagNames.length() - 1
            }
            this.lastStyleTag = tag
            this.lastStyleIdx = idx
        }
        let e = this.cacheTagEnd[idx]
        let k = this.cacheTagStart[idx]
        while (k < e) {
            if (this.cacheFlatProps[k] == prop) { return this.cacheFlatVals[k]; }
            k = k + 1
        }
        return null
    }

    public int colorFor(string tag, string prop, int fallback) {
        if (this.sheet == null) { return fallback; }
        return this.sheet.rawToColor(this.styleRaw(tag, prop), fallback)
    }

    // Valor numérico de una prop CSS (o fallback). Reactivo por ancho vía fullCtx.
    public int numProp(string tag, string prop, int fallback) {
        if (this.sheet == null) { return fallback; }
        let v = this.styleRaw(tag, prop)
        if (v == null) { return fallback; }
        return parseInt(("" + v).trim())
    }

    // Valor string de una prop CSS (o fallback).
    public string strProp(string tag, string prop, string fallback) {
        if (this.sheet == null) { return fallback; }
        let v = this.styleRaw(tag, prop)
        if (v == null) { return fallback; }
        return ("" + v).trim()
    }

    // ── Fuentes (.szs: bloques :font + prop font-family) ───────────────────────

    // Carga las fuentes declaradas en :font { alias: ruta.ttf; } — una sola vez.
    public void ensureFonts() {
        if (this.fontsReady) { return; }
        this.fontsReady = true
        if (this.sheet == null) { return; }
        let i = 0
        while (i < this.sheet.fontCount()) {
            let alias = this.sheet.fontAlias(i)
            let real  = Gui.loadFont(this.sheet.fontPath(i))
            this.fontAliasNames.push(alias)
            this.fontRealNames.push(real)
            i = i + 1
        }
    }

    // Familia efectiva para un tag: su font-family, o la de body como default.
    // Resuelve alias de :font al nombre real. "" = fuente default (rejilla mono).
    public string famFor(string tag) {
        let f = this.strProp(tag, "font-family", "")
        if (f == "" && tag != "body") { f = this.strProp("body", "font-family", ""); }
        if (f == "") { return this.defaultFam; }   // default moderno si la app no fija fuente
        // Quita comillas opcionales: font-family: "Segoe UI"
        if (f.length() >= 2) {
            let a = f.charAt(0)
            let b = f.charAt(f.length() - 1)
            if ((a == "\"" && b == "\"") || (a == "'" && b == "'")) {
                f = f.substring(1, f.length() - 1)
            }
        }
        let i = 0
        while (i < this.fontAliasNames.length()) {
            if (this.fontAliasNames[i] == f) { return this.fontRealNames[i]; }
            i = i + 1
        }
        return f
    }

    // Activa la familia del tag. true si quedó una familia custom activa
    // (el caller debe resetear con this.swSetFont("") al terminar).
    public bool setFam(string tag) {
        let f = this.famFor(tag)
        if (f == "") { return false; }
        return this.swSetFont(f)
    }

    // Como setFam pero SIN heredar la familia de body. Para Input/Textarea: queremos
    // una monoespaciada propia (el caret asume avance uniforme) y NUNCA la
    // proporcional de body. Devuelve true si quedó una familia custom activa.
    public bool setMonoFam(string tag) {
        let f = this.strProp(tag, "font-family", "")
        if (f == "") {
            // Mono moderno por defecto: Cascadia Mono, con fallback a Consolas y a la rejilla.
            if (this.swSetFont(this.defaultMono)) { return true; }
            return this.swSetFont(this.defaultMonoAlt)
        }
        if (f.length() >= 2) {
            let a = f.charAt(0)
            let b = f.charAt(f.length() - 1)
            if ((a == "\"" && b == "\"") || (a == "'" && b == "'")) {
                f = f.substring(1, f.length() - 1)
            }
        }
        let i = 0
        while (i < this.fontAliasNames.length()) {
            if (this.fontAliasNames[i] == f) { return this.swSetFont(this.fontRealNames[i]); }
            i = i + 1
        }
        return this.swSetFont(f)
    }

    // Ancho de un texto con la fuente del tag (mide y restaura la default).
    public int measureFor(string tag, string text, int scale) {
        let active = this.setFam(tag)
        let w = Gui.measureText(text, scale)[0]
        if (active) { this.swSetFont(""); }
        return w
    }

    // Fondo de un control honrando border-radius del .szs.
    public void fillBox(string tag, int bx, int by, int bw, int bh, int color) {
        let rad = this.numProp(tag, "border-radius", 0)
        if (rad > 0) { this.swRoundRect(bx, by, bw, bh, rad, color) }
        else { this.swRect(bx, by, bw, bh, color) }
    }

    // Parte `text` en líneas que entran en `this.colWidth` (texto monoespaciado:
    // 8*scale px/char). Corta por palabras; una palabra más larga que la línea se
    // parte por la fuerza. Respeta los saltos de línea explícitos (\n).
    public any wrapText(string text, int scale) {
        let charW = 8 * scale
        let maxChars = this.colWidth / charW
        if (maxChars < 1) { maxChars = 1; }
        let lines = []
        let paras = text.split("\n")
        let pi = 0
        while (pi < paras.length()) {
            let words = paras[pi].split(" ")
            let cur = ""
            let wi = 0
            while (wi < words.length()) {
                let word = words[wi]
                while (word.length() > maxChars) {        // palabra sola muy larga → cortar
                    if (cur.length() > 0) { lines.push(cur); cur = ""; }
                    lines.push(word.substring(0, maxChars))
                    word = word.substring(maxChars, word.length())
                }
                let candidate = word
                if (cur.length() > 0) { candidate = cur + " " + word; }
                if (candidate.length() > maxChars) {
                    lines.push(cur)
                    cur = word
                } else {
                    cur = candidate
                }
                wi = wi + 1
            }
            lines.push(cur)
            pi = pi + 1
        }
        return lines
    }

    // Como wrapText pero midiendo con la fuente ACTIVA (proporcional): corta por
    // palabras cuando la línea candidata supera el ancho disponible en px.
    public any wrapTextMeasured(string text, int scale) {
        let maxW  = this.colWidth
        let lines = []
        let paras = text.split("\n")
        let pi = 0
        while (pi < paras.length()) {
            let words = paras[pi].split(" ")
            let cur = ""
            let wi = 0
            while (wi < words.length()) {
                let word = words[wi]
                let candidate = word
                if (cur.length() > 0) { candidate = cur + " " + word; }
                if (Gui.measureText(candidate, scale)[0] > maxW && cur.length() > 0) {
                    lines.push(cur)
                    cur = word
                } else {
                    cur = candidate
                }
                wi = wi + 1
            }
            lines.push(cur)
            pi = pi + 1
        }
        return lines
    }

    // Dibuja texto con wrap al ancho disponible y avanza `cy`. `blockGap` es el
    // espacio tras el bloque (calibrado para que 1 línea = el avance previo).
    public void drawWrapped(string tag, string text, int scale, int color, int blockGap) {
        // Fuente del tag (texto suelto hereda la de body).
        let ftag = tag
        if (ftag == "") { ftag = "body"; }
        let custom = this.setFam(ftag)

        let lines = []
        if (tag != "" && this.strProp(tag, "white-space", "normal") == "nowrap") {
            lines = [text]                          // opt-out: una sola línea (puede recortarse)
        } else if (custom) {
            lines = this.wrapTextMeasured(text, scale)
        } else {
            lines = this.wrapText(text, scale)
        }
        let align = "left"
        if (tag != "") { align = this.strProp(tag, "text-align", "left"); }
        // Estilo de fuente desde el .szs: font-weight:bold (bit0) + font-style:italic (bit1).
        // Sin propiedad → 0 → idéntico a antes (texto normal).
        let style = 0
        if (tag != "") {
            if (this.strProp(tag, "font-weight", "normal") == "bold")  { style = style + 1; }
            if (this.strProp(tag, "font-style", "normal")  == "italic"){ style = style + 2; }
        }
        let lh    = 8 * scale + 4
        let maxW  = 0
        let li    = 0
        while (li < lines.length()) {
            let lw = Gui.measureText(lines[li], scale)[0]
            let lx = this.cx
            if (align == "center") { lx = this.cx + (this.colWidth - lw) / 2; }
            else if (align == "right") { lx = this.cx + this.colWidth - lw; }
            this.swText(lx, this.cy + li * lh, lines[li], scale, color, style)
            if (lw > maxW) { maxW = lw; }
            li = li + 1
        }
        this.lastW = maxW
        this.cy = this.cy + lines.length() * lh + (blockGap - 4)
        if (custom) { this.swSetFont(""); }
    }

    public any getRegions() { return this.regions }

    // ── Camino de render NATIVO (Fase 3) ───────────────────────────────────────
    // Baja un VNode al árbol de primitivos del core: [tag, props, [hijos]]. El
    // formato de VNode (tag + props [[n,v]] + children) ya casa con el contrato de
    // Gui.renderTree; solo hay que estringar los hijos primitivos (int/bool → texto)
    // y recursar. Los props (class/id/onClick/estilo inline) viajan tal cual: el core
    // lee los que entiende e ignora el resto.
    // Embebe el VNode ORIGINAL en el attr `onClick` de los props bajados, para que la
    // region del core lo devuelva y handleGuiInput lea todos sus props (onChange/value/…).
    // Dropea cualquier onClick previo (el original ya vive dentro de `node`).
    public any withRef(any baseProps, any node) {
        let rp = [["onClick", node]]
        let i = 0
        while (i < baseProps.length()) {
            if (baseProps[i][0] != "onClick") { rp.push(baseProps[i]) }
            i = i + 1
        }
        return rp
    }

    // DISCIPLINA DE ORDINALES (camino nativo): el core emite las regions en PRE-ORDEN
    // y renderNative filtra solo las que llevan ref (withRef) → índice-de-region ==
    // ordinal de foco ↔ cada withRef debe consumir exactamente un ordinal
    // (`this.focusOrd = this.focusOrd + 1`), en el orden en que su nodo aparece en el
    // árbol (contenedor antes que sus ítems).

    // Estilos del `.szs` del app resueltos para un TAG DE WIDGET, como pares inline
    // [prop, val]. Necesario cuando el lowering CAMBIA el tag (Input→textbox,
    // Image→img, Row→row): el selector por tag del app ya no matchea en el core,
    // así que arrastramos sus decls resueltas (mismo cascade/condiciones que el
    // intérprete via allPropsForTag+ctx) como estilo inline del nodo bajado.
    public any sheetTagStyles(string tag) {
        let sty = []
        if (this.sheet == null) { return sty }
        let pv = this.sheet.allPropsForTag(tag, this.fullCtx)
        let i = 0
        while (i < pv[0].length()) {
            let v = "" + pv[1][i]
            if (v.length() >= 2 && v.substring(0, 1) == "\"" && v.substring(v.length() - 1, v.length()) == "\"") {
                v = v.substring(1, v.length() - 1)
            }
            sty.push([pv[0][i], v])
            i = i + 1
        }
        return sty
    }

    public any lowerVNode(any node) {
        if (node == null) { return ""; }
        if (node is string) { return node; }
        if (node is int || node is decimal || node is bool) { return "" + node; }
        let tag = node.getTag()
        // Widgets: bajan a un primitivo con su estilo característico (lowering).
        if (tag == "Button") { return this.lowerButton(node); }
        if (tag == "Input") { return this.lowerInput(node); }
        if (tag == "Textarea") { return this.lowerTextarea(node); }
        if (tag == "Checkbox") { return this.lowerCheckbox(node); }
        if (tag == "Switch" || tag == "Toggle") { return this.lowerSwitch(node); }
        if (tag == "ProgressBar") { return this.lowerProgressBar(node); }
        if (tag == "Select") { return this.lowerSelect(node); }
        if (tag == "Slider") { return this.lowerSlider(node); }
        if (tag == "Tabs") { return this.lowerTabs(node); }
        if (tag == "RadioGroup") { return this.lowerRadioGroup(node); }
        if (tag == "Dropdown") { return this.lowerDropdown(node); }
        if (tag == "Modal") { return this.lowerModal(node); }
        if (tag == "Collapsible" || tag == "Accordion") { return this.lowerCollapsible(node); }
        if (tag == "Table") { return this.lowerTable(node); }
        if (tag == "Toast") { return this.lowerToast(node); }
        if (tag == "Chart") { return this.lowerChart(node); }
        if (tag == "DropZone") { return this.lowerDropZone(node); }
        if (tag == "Tooltip") { return this.lowerTooltip(node); }
        if (tag == "FileInput") { return this.lowerFileInput(node); }
        // Mapeo de tags de widget a primitivos del core (contenedor/flex/imagen).
        // `Row` → `row` (flex); `Image` → `img`. El resto se mantiene: el core trata
        // los tags desconocidos como contenedores y el `.szs`/UA los estiliza por tag.
        let outTag = tag
        if (tag == "Row") { outTag = "row" }
        else if (tag == "Image") { outTag = "img" }
        // Genérico: VNode → [tag, props, [hijos bajados]]. El ref (y su ordinal) se
        // toma ANTES de bajar los hijos: pre-orden, como emite las regions el core.
        let gprops = node.getProps()
        if (outTag != tag) {
            // El tag cambia → los selectores del .szs del app por el nombre del
            // widget no matchean en el core: inyectar sus estilos resueltos inline
            // (primero, para que los props explícitos del nodo pisen).
            let merged = this.sheetTagStyles(tag)
            let gi = 0
            while (gi < gprops.length()) { merged.push(gprops[gi]); gi = gi + 1 }
            gprops = merged
        }
        if (node.hasProp("onClick") || node.hasProp("onChange") || node.hasProp("onInput") || node.hasProp("onDrop")) {
            this.focusOrd = this.focusOrd + 1
            gprops = this.withRef(gprops, node)
        }
        let kids     = node.getChildren()
        let lowered  = []
        let i = 0
        while (i < kids.length()) {
            lowered.push(this.lowerVNode(kids[i]))
            i = i + 1
        }
        return [outTag, gprops, lowered]
    }

    public any lowerInput(any node) {
        let myOrd   = this.focusOrd
        let disabled = node.getProp("disabled") == true
        let focused  = myOrd == this.focus && !disabled && this.winFocused
        this.focusOrd = this.focusOrd + 1

        // Input baja a `textbox`: defaults del widget (espejo del interpretado:
        // caja de 34px #111827 con borde 2px #334155, foco #60a5fa) + estilos `.szs`
        // del app para `Input` (pisan a los defaults) como inline.
        let props = [["background-color", "#111827"], ["border-width", "2"], ["border-color", "#334155"], ["padding", "7"], ["height", "34"]]
        let ss = this.sheetTagStyles("Input")
        let si = 0
        while (si < ss.length()) { props.push(ss[si]); si = si + 1 }
        let op = node.getProps()
        let pi = 0
        let hasCaret = false
        let hasFocused = false
        let hasSelStart = false
        let hasSelEnd = false
        while (pi < op.length()) {
            props.push(op[pi])
            if (op[pi][0] == "caret") { hasCaret = true; }
            if (op[pi][0] == "focused") { hasFocused = true; }
            if (op[pi][0] == "sel-start") { hasSelStart = true; }
            if (op[pi][0] == "sel-end") { hasSelEnd = true; }
            pi = pi + 1
        }

        if (!hasFocused) {
            if (focused) { props.push(["focused", "true"]); }
            else         { props.push(["focused", "false"]); }
        }
        if (!hasCaret && focused) {
            props.push(["caret", "" + this.caret])
        }
        if (!hasSelStart && focused && this.selAnchor >= 0) {
            props.push(["sel-start", "" + this.selAnchor])
            props.push(["sel-end", "" + this.caret])
        }
        if (focused) { props.push(["border-color", "#60a5fa"]) }
        props.push(["rows", "1"])

        // El texto a renderizar dentro de la caja de texto son sus hijos en el core
        let val = node.getProp("value")
        let text = ""
        if (val != null) { text = "" + val; }
        // Placeholder (como el interpretado): con el valor vacío se muestra el
        // placeholder en color muted; el color del texto vuelve al escribir.
        if (text == "") {
            let ph = node.getProp("placeholder")
            if (ph != null) {
                text = "" + ph
                props.push(["color", "#64748b"])
            }
        }
        return ["textbox", this.withRef(props, node), [text]]
    }

    public any lowerTextarea(any node) {
        let myOrd   = this.focusOrd
        let disabled = node.getProp("disabled") == true
        let focused  = myOrd == this.focus && !disabled && this.winFocused
        this.focusOrd = this.focusOrd + 1

        // Textarea baja a `textbox`: mismos defaults que Input + estilos `.szs` del
        // app para `Textarea` (pisan) como inline.
        let props = [["background-color", "#111827"], ["border-width", "2"], ["border-color", "#334155"], ["padding", "7"]]
        let ss = this.sheetTagStyles("Textarea")
        let si = 0
        while (si < ss.length()) { props.push(ss[si]); si = si + 1 }
        let op = node.getProps()
        let pi = 0
        let hasCaret = false
        let hasFocused = false
        let hasSelStart = false
        let hasSelEnd = false
        let hasRows = false
        while (pi < op.length()) {
            props.push(op[pi])
            if (op[pi][0] == "caret") { hasCaret = true; }
            if (op[pi][0] == "focused") { hasFocused = true; }
            if (op[pi][0] == "sel-start") { hasSelStart = true; }
            if (op[pi][0] == "sel-end") { hasSelEnd = true; }
            if (op[pi][0] == "rows") { hasRows = true; }
            pi = pi + 1
        }

        if (!hasFocused) {
            if (focused) { props.push(["focused", "true"]); }
            else         { props.push(["focused", "false"]); }
        }
        if (!hasCaret && focused) {
            props.push(["caret", "" + this.caret])
        }
        if (!hasSelStart && focused && this.selAnchor >= 0) {
            props.push(["sel-start", "" + this.selAnchor])
            props.push(["sel-end", "" + this.caret])
        }

        let r = node.getProp("rows")
        if (r == null) { r = 6; }
        let visRows = r
        if (visRows is string) { visRows = parseInt(visRows); }

        if (!hasRows) {
            props.push(["rows", "" + visRows])
        }
        if (focused) { props.push(["border-color", "#60a5fa"]) }

        let val = node.getProp("value")
        let text = ""
        if (val != null) { text = "" + val; }

        let lines = text.split("\n")
        let totalSegs = lines.length()
        let startSeg = this.getTaScroll(myOrd)
        if (startSeg > totalSegs - visRows) { startSeg = totalSegs - visRows; }
        if (startSeg < 0) { startSeg = 0; }

        node.setProp("ta-ord", myOrd)
        node.setProp("ta-total", totalSegs)
        node.setProp("ta-vis", visRows)

        let slicedLines = []
        let li = startSeg
        let limit = startSeg + visRows
        if (limit > totalSegs) { limit = totalSegs; }
        while (li < limit) {
            slicedLines.push(lines[li])
            li = li + 1
        }
        let slicedText = slicedLines.join("\n")

        if (slicedText == "") {
            let ph = node.getProp("placeholder")
            if (ph != null) {
                slicedText = "" + ph
                props.push(["color", "#64748b"])
            }
        }
        return ["textbox", this.withRef(props, node), [slicedText]]
    }

    public any lowerSlider(any node) {
        let value    = node.getProp("value")
        let min      = node.getProp("min")
        let max      = node.getProp("max")
        let disabled = node.getProp("disabled") == true
        if (min == null) { min = 0; }
        if (max == null) { max = 100; }
        if (value == null) { value = min; }

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let span = max - min
        if (span <= 0) { span = 1; }
        let rel = value - min
        if (rel < 0) { rel = 0; }
        if (rel > span) { rel = span; }
        let fillPct = (rel * 100) / span

        // El REF va en la PISTA (tag "Slider"): handleGuiInput mapea el clic a valor
        // con rg[1]/rg[3] de la region, que deben ser los de la pista (sin el label).
        // El contenedor queda como div.Slider sin ref (no genera region filtrada).
        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) {
            if (op[pi][0] != "onClick") { props.push(op[pi]) }
            pi = pi + 1
        }
        props.push(["height", "30"])

        let trackProps = this.withRef([
            ["class", "slider-track"],
            ["position", "relative"],
            ["height", "30"]
        ], node)

        let trackBgProps = [
            ["class", "slider-track-bg"],
            ["position", "absolute"],
            ["left", "0"],
            ["top", "13"],
            ["width", "100%"],
            ["height", "4"]
        ]

        let fillProps = [
            ["class", "slider-fill"],
            ["position", "absolute"],
            ["left", "0"],
            ["top", "13"],
            ["width", "" + fillPct + "%"],
            ["height", "4"]
        ]

        let knobProps = [
            ["class", "slider-knob"],
            ["position", "absolute"],
            ["left", "" + fillPct + "%"],
            ["top", "6"],
            ["width", "10"],
            ["height", "18"]
        ]

        let labelProps = [
            ["class", "slider-label"],
            ["width", "44"]
        ]

        let trackKids = [
            ["div", trackBgProps, []],
            ["div", fillProps, []],
            ["div", knobProps, []]
        ]

        let containerClass = "Slider"
        if (focused) { containerClass = "Slider focused"; }
        props.push(["class", containerClass])

        return ["div", props, [
            ["Slider", trackProps, trackKids],
            ["span", labelProps, ["" + value]]
        ]]
    }

    public any lowerTabs(any node) {
        let tabs = node.getProp("tabs")
        if (tabs == null) { tabs = []; }
        let active = node.getProp("active")
        if (active == null) { active = 0; }
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }

        let containerClass = "Tabs"
        if (focused) { containerClass = "Tabs focused"; }
        props.push(["class", containerClass])
        props.push(["height", "34"])
        props.push(["position", "relative"])

        let kids = []
        
        let barLineProps = [
            ["class", "tabs-bottom-border"],
            ["position", "absolute"],
            ["left", "0"],
            ["bottom", "0"],
            ["width", "100%"],
            ["height", "1"]
        ]
        kids.push(["div", barLineProps, []])

        let rowProps = [
            ["class", "tabs-row"],
            ["width", "100%"],
            ["height", "33"]
        ]

        let rowKids = []
        let totW = 0
        let i = 0
        while (i < tabs.length()) {
            let label = "" + tabs[i]
            let isAct = (i == active)
            
            let tabClass = "tab-item"
            if (isAct) { tabClass = "tab-item active-tab"; }
            if (disabled) { tabClass = "tab-item disabled-tab"; }
            
            let tabIndex = i
            // Ancho al contenido (como el intérprete): label + 2·14 de padding horizontal.
            let tw = Gui.measureText(label, 2)[0] + 28
            let tabProps = [
                ["class", tabClass],
                ["width", "" + tw],
                ["height", "33"],
                ["position", "relative"]
            ]
            
            let tabKids = [["span", [], [label]]]
            if (isAct) {
                let underlineProps = [
                    ["class", "tab-underline"],
                    ["position", "absolute"],
                    ["left", "0"],
                    ["bottom", "0"],
                    ["width", "100%"],
                    ["height", "3"]
                ]
                tabKids.push(["div", underlineProps, []])
            }

            if (!disabled) {
                let oc = node.getProp("onChange")
                let tabNode = new VNode("TabItem", [["onClick", () => { if (oc != null) { oc(tabIndex); } }]], [label])
                this.focusOrd = this.focusOrd + 1
                tabProps = this.withRef(tabProps, tabNode)
            }
            
            rowKids.push(["div", tabProps, tabKids])
            totW = totW + tw
            i = i + 1
        }

        kids.push(["row", rowProps, rowKids])

        if (focused) {
            // Anillo de foco = paridad con drawFocusRing del interpretado (marco de
            // 2px alrededor de la tira). El UA usa un selector descendiente
            // (`Tabs.focused .tabs-bottom-border`), inerte en el core → el lowering
            // dibuja el anillo con 4 divs absolutos dentro del contenedor.
            let rc = "#60a5fa"
            kids.push(["div", [["position", "absolute"], ["left", "0"], ["top", "0"], ["width", "" + totW], ["height", "2"], ["background-color", rc]], []])
            kids.push(["div", [["position", "absolute"], ["left", "0"], ["bottom", "0"], ["width", "" + totW], ["height", "2"], ["background-color", rc]], []])
            kids.push(["div", [["position", "absolute"], ["left", "0"], ["top", "0"], ["width", "2"], ["height", "34"], ["background-color", rc]], []])
            kids.push(["div", [["position", "absolute"], ["left", "" + (totW - 2)], ["top", "0"], ["width", "2"], ["height", "34"], ["background-color", rc]], []])
        }

        return ["Tabs", this.withRef(props, node), kids]
    }

    public any lowerRadioGroup(any node) {
        let value    = node.getProp("value")
        let options  = node.getProp("options")
        let disabled = node.getProp("disabled") == true
        if (options == null) { options = []; }

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let containerClass = "RadioGroup"
        if (focused) { containerClass = "RadioGroup focused"; }
        props.push(["class", containerClass])
        
        let totalH = options.length() * 26
        if (totalH == 0) { totalH = 26; }
        props.push(["height", "" + totalH])

        let kids = []
        let i = 0
        while (i < options.length()) {
            let opt = options[i]
            let selected = ("" + opt) == ("" + value)
            
            let indClass = "radio-indicator"
            if (disabled) { indClass = "radio-indicator disabled-indicator"; }
            let indProps = [
                ["class", indClass],
                ["width", "18"],
                ["height", "18"],
                ["position", "relative"]
            ]
            
            let indKids = []
            if (selected) {
                let dotClass = "radio-dot"
                if (disabled) { dotClass = "radio-dot disabled-dot"; }
                indKids.push(["div", [
                    ["class", dotClass],
                    ["position", "absolute"],
                    ["left", "5"],
                    ["top", "5"],
                    ["width", "8"],
                    ["height", "8"]
                ], []])
            }
            
            let labelClass = "radio-label"
            if (disabled) { labelClass = "radio-label disabled-label"; }
            
            let rowProps = [
                ["class", "radio-row"],
                ["height", "26"]
            ]
            
            kids.push(["row", rowProps, [
                ["div", indProps, indKids],
                ["span", [["class", labelClass]], ["" + opt]]
            ]])
            i = i + 1
        }

        return ["RadioGroup", this.withRef(props, node), kids]
    }

    public any lowerDropdown(any node) {
        let value    = node.getProp("value")
        let disabled = node.getProp("disabled") == true
        let options  = node.getProp("options")
        if (options == null) { options = []; }

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1
        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }

        let containerClass = "Dropdown"
        if (focused) { containerClass = "Dropdown focused"; }
        props.push(["class", containerClass])
        props.push(["height", "34"])
        props.push(["position", "relative"])

        let kids = [
            ["span", [["class", "dropdown-value"]], ["" + value]],
            ["span", [["class", "dropdown-arrow"]], ["▼"]]
        ]

        if (focused && this.dropOpen) {
            let overlayKids = []
            let i = 0
            while (i < options.length()) {
                let opt = options[i]
                let optClass = "dropdown-option"
                if (i == this.dropHi) { optClass = "dropdown-option active-option"; }
                
                let optProps = [
                    ["class", optClass],
                    ["height", "30"]
                ]
                
                overlayKids.push(["div", optProps, ["" + opt]])
                i = i + 1
            }
            
            let overlayProps = [
                ["class", "dropdown-overlay"],
                ["position", "absolute"],
                ["left", "0"],
                ["top", "34"],
                ["width", "100%"],
                ["z-index", "1000"]
            ]
            
            kids.push(["div", overlayProps, overlayKids])
        }

        return ["Dropdown", this.withRef(props, node), kids]
    }

    public any lowerModal(any node) {
        if (node.getProp("open") != true) { return ""; }
        this.hasModal = true
        this.modalNode = node
        return ""
    }

    public any lowerModalOverlay() {
        let node = this.modalNode
        if (node == null) { return ""; }
        
        let title = node.getProp("title")
        let onClose = node.getProp("onClose")
        
        let boxKids = []
        
        if (title != null || onClose != null) {
            let headerKids = []
            if (title != null) {
                headerKids.push(["span", [["class", "modal-title"]], ["" + title]])
            }
            if (onClose != null) {
                let closeNode = new VNode("ModalClose", [["onClick", onClose]], ["x"])
                this.focusOrd = this.focusOrd + 1
                let closeProps = [["class", "modal-close"]]
                closeProps = this.withRef(closeProps, closeNode)
                headerKids.push(["ModalClose", closeProps, ["x"]])
            }
            boxKids.push(["row", [["class", "modal-header"]], headerKids])
            boxKids.push(["div", [["class", "modal-divider"]], []])
        }
        
        let kids = node.getChildren()
        let i = 0
        while (i < kids.length()) {
            boxKids.push(this.lowerVNode(kids[i]))
            i = i + 1
        }
        
        let mw = this.w * 3 / 4
        if (mw > 520) { mw = 520; }
        if (mw < 240) { mw = 240; }
        let mh = this.h * 3 / 5
        if (mh > 360) { mh = 360; }
        if (mh < 140) { mh = 140; }
        this.modalBoxW = mw
        this.modalBoxH = mh
        this.modalBoxX = (this.w - mw) / 2
        this.modalBoxY = (this.h - mh) / 2
        
        let boxProps = [
            ["class", "modal-box"],
            ["width", "" + mw],
            ["height", "" + mh]
        ]
        
        // El backdrop cubre la VENTANA entera (en px: el 100% se resolvería contra el
        // ancho de contenido del árbol, que ya descontó el padding).
        let backdropProps = [
            ["class", "modal-backdrop"],
            ["position", "absolute"],
            ["left", "0"],
            ["top", "0"],
            ["width", "" + this.w],
            ["height", "" + this.h],
            ["z-index", "990"]
        ]
        
        return ["div", backdropProps, [
            ["div", boxProps, boxKids]
        ]]
    }

    public any lowerCollapsible(any node) {
        let title = node.getProp("title")
        if (title == null) { title = ""; }
        let open  = node.getProp("open") == true
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let containerClass = "Collapsible"
        if (focused) { containerClass = "Collapsible focused"; }
        props.push(["class", containerClass])
        props.push(["display", "block"])

        // Chevron ASCII (">"/"v": los glifos ▶/▼ no están en la familia default) con
        // ancho fijo: en el flex del header, el título toma el resto y queda a la izquierda.
        let chevron = ">"
        if (open) { chevron = "v"; }

        let headKids = [
            ["span", [["class", "collapsible-chevron"], ["width", "18"]], [chevron]],
            ["span", [["class", "collapsible-title"]], ["" + title]]
        ]

        let headClass = "collapsible-header"
        if (disabled) { headClass = "collapsible-header disabled-header"; }

        // El REF va en el HEADER (tag "Collapsible"): como en el intérprete, solo el
        // header togglea; un clic en el body no debe disparar onToggle.
        let kids = [
            ["Collapsible", this.withRef([["class", headClass], ["height", "32"], ["display", "flex"]], node), headKids]
        ]

        if (open) {
            let bodyKids = []
            let cn = node.getChildren()
            let ci = 0
            while (ci < cn.length()) {
                bodyKids.push(this.lowerVNode(cn[ci]))
                ci = ci + 1
            }
            kids.push(["div", [["class", "collapsible-body"]], bodyKids])
        }

        return ["div", props, kids]
    }

    public any lowerTable(any node) {
        let columns = node.getProp("columns")
        let rows    = node.getProp("rows")
        if (columns == null) { columns = []; }
        if (rows == null) { rows = []; }
        let ncol = columns.length()
        if (ncol == 0 && rows.length() > 0) { ncol = rows[0].length(); }
        if (ncol == 0) { return ""; }
        this.focusOrd = this.focusOrd + 1

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        props.push(["class", "Table"])
        props.push(["display", "block"])

        let kids = []

        if (columns.length() > 0) {
            let headCols = []
            let c = 0
            while (c < ncol) {
                let label = ""
                if (c < columns.length()) { label = "" + columns[c]; }
                headCols.push(["div", [["class", "table-cell"], ["flex", "1"]], [label]])
                c = c + 1
            }
            kids.push(["row", [["class", "table-header-row"]], headCols])
        }

        let r2 = 0
        while (r2 < rows.length()) {
            let row = rows[r2]
            let rowCols = []
            let c2 = 0
            while (c2 < ncol) {
                let cell = ""
                if (c2 < row.length()) { cell = "" + row[c2]; }
                rowCols.push(["div", [["class", "table-cell"], ["flex", "1"]], [cell]])
                c2 = c2 + 1
            }
            let rowClass = "table-row"
            if (r2 % 2 == 1) { rowClass = "table-row table-row-alt"; }
            kids.push(["row", [["class", rowClass]], rowCols])
            r2 = r2 + 1
        }

        return ["Table", this.withRef(props, node), kids]
    }

    public any lowerToast(any node) {
        this.focusOrd = this.focusOrd + 1
        let msg = node.getProp("message")
        if (msg == null) { msg = this.collectText(node); }
        let kind = node.getProp("kind")
        if (kind == null) { kind = "info"; }

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let containerClass = "Toast toast-" + kind
        props.push(["class", containerClass])
        props.push(["height", "34"])

        return ["Toast", this.withRef(props, node), [
            ["span", [["class", "toast-message"]], ["" + msg]]
        ]]
    }

    // Color de prop (int 0xRRGGBB o string "#...") → string "#rrggbb" para el core.
    public string cssHex(any c) {
        let s = "" + c
        if (s.length() > 0 && s.substring(0, 1) == "#") { return s }
        let v = 0 + c
        if (v < 0) { v = 0 }
        let digits = "0123456789abcdef"
        let hex = ""
        let i = 0
        while (i < 6) {
            let d = v % 16
            hex = digits.substring(d, d + 1) + hex
            v = v / 16
            i = i + 1
        }
        return "#" + hex
    }

    public any lowerChart(any node) {
        this.focusOrd = this.focusOrd + 1
        let data = node.getProp("data")
        if (data == null) { data = []; }
        let ctype = node.getProp("type")
        if (ctype == null) { ctype = "line"; }
        let bh = node.getProp("height")
        if (bh == null) { bh = 160; }
        let color = node.getProp("color")

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let containerClass = "Chart"
        props.push(["class", containerClass])
        props.push(["height", "" + bh])
        props.push(["position", "relative"])

        let kids = []

        // Rango de datos (min/max explícitos o derivados).
        let ymin = node.getProp("min")
        let ymax = node.getProp("max")
        if (data.length() > 0 && (ymin == null || ymax == null)) {
            let lo = data[0]
            let hi = data[0]
            let k = 1
            while (k < data.length()) {
                if (data[k] < lo) { lo = data[k]; }
                if (data[k] > hi) { hi = data[k]; }
                k = k + 1
            }
            if (ymin == null) { ymin = lo; }
            if (ymax == null) { ymax = hi; }
        }
        if (ymin == null) { ymin = 0; }
        if (ymax == null) { ymax = 1; }
        let span = ymax - ymin
        if (span <= 0) { span = 1; }
        // Altura interna en PX (el core resuelve height:% contra la VENTANA, no el
        // padre — acá conocemos bh, así que bajamos todo en píxeles).
        let innerH = bh - 16
        if (innerH < 10) { innerH = 10; }

        if (ctype == "bar" && data.length() > 0) {
            let barKids = []
            let i = 0
            while (i < data.length()) {
                let rel = data[i] - ymin
                if (rel < 0) { rel = 0; }
                let fh = (rel * innerH) / span
                if (fh < 1) { fh = 1; }

                let barColProps = [
                    ["class", "chart-bar-col"],
                    ["flex", "1"],
                    ["height", "" + innerH],
                    ["position", "relative"]
                ]
                let barFillProps = [
                    ["class", "chart-bar-fill"],
                    ["position", "absolute"],
                    ["left", "2"],
                    ["bottom", "0"],
                    ["width", "80%"],
                    ["height", "" + fh]
                ]
                // Prop `color` del Chart (int 0xRRGGBB) → color de barra (como el
                // interpretado); sin él, el UA da el azul por defecto.
                if (color != null) { barFillProps.push(["background-color", this.cssHex(color)]) }
                // Barras muy finas: sin radius (el border-radius del UA infla una
                // barra de 1-3px a un "guion" visible — con muchos buckets vacíos
                // el histograma parecía una fila de rayitas).
                if (fh <= 3) { barFillProps.push(["border-radius", "0"]) }
                // Bucket sin datos → SIN barra (queda solo la línea base, como se ve
                // en el interpretado, donde el 1px se funde con la baseline).
                let colKids = []
                if (rel > 0) { colKids.push(["div", barFillProps, []]) }
                barKids.push(["div", barColProps, colKids])
                i = i + 1
            }
            kids.push(["row", [["class", "chart-bars-row"], ["width", "100%"], ["height", "" + innerH]], barKids])
            // Línea BASE en y=0 (paridad con el interpretado: swLine en baseY color
            // #334155) — sin ella los buckets vacíos parecen datos sueltos.
            kids.push(["div", [["position", "absolute"], ["left", "0"], ["top", "" + (8 + innerH)], ["width", "100%"], ["height", "1"], ["background-color", "#334155"]], []])
        } else if (data.length() > 1) {
            // "line"/"area" → polyline nativo. El ancho del plot se estima con el ancho
            // de contenido de la ventana (el Chart ocupa el ancho disponible).
            let plotW = this.w - 2 * this.pad - 20
            if (plotW < 40) { plotW = 40; }
            let pts = ""
            let j = 0
            while (j < data.length()) {
                let rel2 = data[j] - ymin
                if (rel2 < 0) { rel2 = 0; }
                let px = (j * (plotW - 1)) / (data.length() - 1)
                let py = innerH - (rel2 * innerH) / span
                if (j > 0) { pts = pts + " "; }
                pts = pts + px + "," + py
                j = j + 1
            }
            let lineCol = "#3b82f6"
            // `color` llega como INT (0xRRGGBB) desde JSX: "" + color daría el
            // DECIMAL ("3900150"), que el core no parsea → convertir a "#rrggbb".
            if (color != null) { lineCol = this.cssHex(color); }
            kids.push(["div", [["class", "chart-plot"], ["height", "" + innerH], ["margin", "8"]], [
                ["polyline", [["points", pts], ["color", lineCol], ["stroke-width", "2"], ["height", "" + innerH]], []]
            ]])
        } else {
            let label = "Gráfico " + ctype
            kids.push(["span", [["class", "chart-fallback-label"]], [label]])
        }

        return ["Chart", this.withRef(props, node), kids]
    }

    public any lowerDropZone(any node) {
        this.focusOrd = this.focusOrd + 1
        let label = node.getProp("label")
        if (label == null) { label = "Arrastra archivos aqui"; }
        let bh = node.getProp("height")
        if (bh == null) { bh = 120; }

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let containerClass = "DropZone"
        if (this.filesHovering) { containerClass = "DropZone files-hovering"; }
        props.push(["class", containerClass])
        props.push(["height", "" + bh])
        props.push(["display", "flex"])
        props.push(["justify-content", "center"])
        props.push(["align-items", "center"])

        return ["DropZone", this.withRef(props, node), [
            ["span", [["class", "dropzone-label"]], ["" + label]]
        ]]
    }

    public any lowerTooltip(any node) {
        this.focusOrd = this.focusOrd + 1
        let tip = node.getProp("tip")
        
        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        props.push(["class", "Tooltip"])
        props.push(["position", "relative"])

        let kids = []
        let cn = node.getChildren()
        let i = 0
        while (i < cn.length()) {
            kids.push(this.lowerVNode(cn[i]))
            i = i + 1
        }

        if (this.hasTip && this.tipText == "" + tip) {
            let tipBox = [
                ["class", "tooltip-box"],
                ["position", "absolute"],
                ["left", "20"],
                ["top", "20"],
                ["z-index", "1010"]
            ]
            kids.push(["div", tipBox, ["" + tip]])
        }

        return ["Tooltip", this.withRef(props, node), kids]
    }

    public any lowerFileInput(any node) {
        let label = node.getProp("label")
        if (label == null) { label = "Elegir archivo..."; }
        let value = node.getProp("value")
        let placeholder = node.getProp("placeholder")
        if (placeholder == null) { placeholder = "Ningun archivo"; }
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let containerClass = "FileInput"
        if (focused) { containerClass = "FileInput focused"; }
        props.push(["class", containerClass])
        props.push(["height", "40"])

        let btnClass = "fileinput-button"
        if (disabled) { btnClass = "fileinput-button fileinput-button-disabled"; }

        let shown = placeholder
        if (value != null && ("" + value) != "") {
            shown = this.baseName("" + value)
        }

        // El REF va en el BOTÓN (tag "FileInput"): como en el intérprete, solo el botón
        // abre el picker; el texto del archivo elegido no es clickeable.
        let kids = [
            ["FileInput", this.withRef([["class", btnClass], ["width", "140"], ["height", "40"]], node), [label]],
            ["span", [["class", "fileinput-value"]], [shown]]
        ]

        return ["div", props, kids]
    }

    // Select → caja bordeada con el valor entre "< … >" (clic cicla vía onChange).
    // Espeja renderSelect. La lógica de ciclado vive en handleGuiInput (lee el node).
    public any lowerSelect(any node) {
        let value    = node.getProp("value")
        let disabled = node.getProp("disabled") == true
        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let display = "< " + value + " >"
        if (disabled) { display = "  " + value + "  "; }

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        let cls = "Select"
        if (focused) { cls = "Select focused"; }
        props.push(["class", cls])
        props.push(["height", "34"])
        return ["Select", this.withRef(props, node), [display]]
    }

    // Button → caja COMPACTA (ancho = label + padding) alineada a la izquierda, con
    // font-scale 2 y separación abajo. Conserva onClick y el tag "Button" para que el
    // `.szs` (bg/color/border-radius por tag) siga aplicando. Espeja renderButton.
    public any lowerButton(any node) {
        this.focusOrd = this.focusOrd + 1
        let kids  = node.getChildren()
        let label = ""
        let i = 0
        while (i < kids.length()) {
            let k = kids[i]
            if (k is string) { label = label + k } else { label = label + ("" + k) }
            i = i + 1
        }
        let w = Gui.measureText(label, 2)[0] + 28   // = renderButton: m[0] + 28
        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }   // conserva onClick/disabled/…
        props.push(["width", "" + w])            // ancho compacto (el resto del look → UA/.szs)
        return ["Button", this.withRef(props, node), [label]]
    }

    public any lowerCheckbox(any node) {
        let checked = node.getProp("checked") == true
        let label   = node.getProp("label")
        if (label == null) { label = this.collectText(node); }
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        
        let lm = Gui.measureText("" + label, 2)
        let regW = 28 + lm[0]
        props.push(["width", "" + regW])
        props.push(["height", "20"])

        let boxClass = "checkbox-box"
        if (focused) { boxClass = "checkbox-box focused-box"; }
        let boxProps = [["class", boxClass], ["width", "20"], ["height", "20"]]
        let checkChar = ""
        if (checked) { checkChar = "X"; }

        let labelProps = [["class", "checkbox-label"]]

        let containerClass = "Checkbox"
        if (focused) { containerClass = "Checkbox focused"; }
        props.push(["class", containerClass])

        return ["Checkbox", this.withRef(props, node), [
            ["div", boxProps, [checkChar]],
            ["span", labelProps, ["" + label]]
        ]]
    }

    public any lowerSwitch(any node) {
        let checked  = node.getProp("checked") == true
        let label    = node.getProp("label")
        if (label == null) { label = this.collectText(node); }
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let lm   = Gui.measureText("" + label, 2)
        let regW = 44 + 8 + lm[0]

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        props.push(["width", "" + regW])
        props.push(["height", "22"])

        let trackClass = "switch-track"
        if (checked) { trackClass = "switch-track checked-track"; }
        if (disabled) { trackClass = "switch-track disabled-track"; }
        let trackProps = [["class", trackClass], ["width", "44"], ["height", "22"], ["position", "relative"]]

        let knobClass = "switch-knob"
        if (disabled) { knobClass = "switch-knob disabled-knob"; }
        let leftPx = "3"
        if (checked) { leftPx = "25"; }
        let knobProps = [
            ["class", knobClass],
            ["position", "absolute"],
            ["left", leftPx],
            ["top", "3"],
            ["width", "16"],
            ["height", "16"]
        ]

        let labelProps = [["class", "switch-label"]]
        let labelNode = []
        if (("" + label) != "") {
            labelNode = [["span", labelProps, ["" + label]]]
        }

        let containerClass = "Switch"
        if (focused) { containerClass = "Switch focused"; }
        props.push(["class", containerClass])

        let swkids = [["div", trackProps, [["div", knobProps, []]]]]
        let sli = 0
        while (sli < labelNode.length()) { swkids.push(labelNode[sli]); sli = sli + 1 }
        return ["Switch", this.withRef(props, node), swkids]
    }

    public any lowerProgressBar(any node) {
        this.focusOrd = this.focusOrd + 1
        let value = node.getProp("value")
        let max   = node.getProp("max")
        let label = node.getProp("label")
        if (value == null) { value = 0; }
        if (max == null) { max = 100; }

        let span = max
        if (span <= 0) { span = 1; }
        let v = value
        if (v < 0) { v = 0; }
        if (v > span) { v = span; }

        let fillPct = (v * 100) / span

        let props = []
        let op = node.getProps()
        let pi = 0
        while (pi < op.length()) { props.push(op[pi]); pi = pi + 1 }
        props.push(["class", "ProgressBar"])
        props.push(["height", "22"])

        let fillProps = [
            ["class", "progressbar-fill"],
            ["width", "" + fillPct + "%"],
            ["height", "22"]
        ]

        let labelNode = []
        if (label != null) {
            labelNode = [["span", [["class", "progressbar-label"]], ["" + label]]]
        }

        let pbkids = [["div", fillProps, []]]
        let pli = 0
        while (pli < labelNode.length()) { pbkids.push(labelNode[pli]); pli = pli + 1 }
        return ["ProgressBar", this.withRef(props, node), pbkids]
    }

    // Render nativo: carga el .szs en el core (una vez), baja el VDOM y delega el
    // layout+CSS+paint a Gui.renderTree. Rearma this.regions con VNodes envoltorio
    // (onClick) para que handleGuiInput enrute los clics sin cambios.
    // Hoja "user-agent": defaults por tag que ESPEJAN al intérprete (escalas, color
    // muted de p/span/li, gaps verticales, look base de widgets). Va ANTES del .szs del
    // app en la hoja combinada, así el `.szs` la pisa ("última gana" en el core).
    public string uaStyles() {
        return "h1 \{ font-scale: 3; color: #e2e8f0; margin-bottom: 8 \}"
            + " h2 \{ font-scale: 2; color: #e2e8f0; margin-bottom: 6 \}"
            + " h3 \{ font-scale: 2; color: #e2e8f0; margin-bottom: 4 \}"
            + " p \{ font-scale: 2; color: #94a3b8; margin-bottom: 4 \}"
            + " span \{ font-scale: 2; color: #94a3b8 \}"
            + " li \{ font-scale: 2; color: #94a3b8; margin-bottom: 4 \}"
            + " hr \{ color: #334155; margin-bottom: 12 \}"
            + " Button \{ background-color: #3b82f6; color: #e2e8f0; padding: 10; font-scale: 2; margin-bottom: 10 \}"
            + " Label \{ font-scale: 2; color: #e2e8f0; margin-bottom: 4 \}"
            + " Link \{ font-scale: 2; color: #60a5fa; margin-bottom: 4 \}"
            + " Badge \{ background-color: #334155; color: #e2e8f0; padding: 4; font-scale: 1; border-radius: 6 \}"
            + " Checkbox \{ display: flex; direction: row; align-items: center; gap: 8; margin-bottom: 12 \}"
            + " .checkbox-box \{ background-color: #111827; border: 1px solid #334155; display: flex; justify-content: center; align-items: center; color: #e2e8f0; font-scale: 2 \}"
            + " .checkbox-label \{ color: #e2e8f0; font-scale: 2 \}"
            + " .focused-box \{ border-color: #60a5fa \}"
            + " Switch \{ display: flex; direction: row; align-items: center; gap: 8; margin-bottom: 12 \}"
            + " .switch-track \{ background-color: #334155; border-radius: 11; position: relative \}"
            + " .switch-track.checked-track \{ background-color: #3b82f6 \}"
            + " .switch-track.disabled-track \{ background-color: #334155 \}"
            + " .switch-knob \{ background-color: #e2e8f0; border-radius: 8 \}"
            + " .switch-knob.disabled-knob \{ background-color: #94a3b8 \}"
            + " .switch-label \{ color: #e2e8f0; font-scale: 2 \}"
            + " Switch.focused .switch-track \{ border: 1px solid #60a5fa \}"
            + " Select \{ background-color: #1e293b; border: 1px solid #334155; color: #e2e8f0; padding: 8; font-scale: 2; border-radius: 4; margin-bottom: 12 \}"
            + " Select.focused \{ border-color: #60a5fa \}"
            + " ProgressBar \{ background-color: #111827; height: 22; display: block; position: relative; margin-bottom: 12 \}"
            + " .progressbar-fill \{ background-color: #3b82f6; position: absolute; left: 0; top: 0 \}"
            + " .progressbar-label \{ color: #e2e8f0; font-scale: 1; position: absolute; left: 8; top: 4 \}"
            + " .Slider \{ display: flex; direction: row; align-items: center; gap: 12; margin-bottom: 12; height: 30 \}"
            + " .slider-track \{ flex: 1 \}"
            + " .slider-track-bg \{ background-color: #334155 \}"
            + " .slider-fill \{ background-color: #3b82f6 \}"
            + " .slider-knob \{ background-color: #3b82f6; border-radius: 2 \}"
            + " .slider-label \{ color: #e2e8f0; font-scale: 2; text-align: right \}"
            + " Slider.focused .slider-knob \{ background-color: #60a5fa \}"
            + " Tabs \{ display: block; position: relative; margin-bottom: 12; height: 34 \}"
            + " .tabs-bottom-border \{ background-color: #334155 \}"
            + " .tabs-row \{ display: flex; direction: row; align-items: center \}"
            + " .tab-item \{ padding: 8 14; color: #94a3b8; font-scale: 2; display: flex; justify-content: center; align-items: center; position: relative \}"
            + " .tab-item.active-tab \{ color: #e2e8f0; background-color: #1e293b \}"
            + " .tab-item.disabled-tab \{ color: #475569 \}"
            + " .tab-underline \{ background-color: #3b82f6 \}"
            + " Tabs.focused .tabs-bottom-border \{ background-color: #60a5fa \}"
            + " RadioGroup \{ display: block; margin-bottom: 10 \}"
            + " .radio-row \{ display: flex; direction: row; align-items: center; gap: 8; height: 26 \}"
            + " .radio-indicator \{ background-color: #111827; border: 1px solid #334155; border-radius: 9 \}"
            + " .radio-dot \{ background-color: #3b82f6; border-radius: 4 \}"
            + " .radio-label \{ color: #e2e8f0; font-scale: 2 \}"
            + " .radio-label.disabled-label \{ color: #475569 \}"
            + " .radio-indicator.disabled-indicator \{ border-color: #475569 \}"
            + " .radio-dot.disabled-dot \{ background-color: #475569 \}"
            + " RadioGroup.focused \{ border: 1px solid #60a5fa \}"
            + " Dropdown \{ display: flex; direction: row; align-items: center; justify-content: space-between; background-color: #1e293b; border: 1px solid #334155; padding: 0 10; border-radius: 4; margin-bottom: 12; height: 34; position: relative \}"
            + " .dropdown-value \{ color: #e2e8f0; font-scale: 2 \}"
            + " .dropdown-arrow \{ color: #94a3b8; font-scale: 1; margin-left: 8 \}"
            + " Dropdown.focused \{ border-color: #60a5fa \}"
            + " .dropdown-overlay \{ background-color: #1e293b; border: 1px solid #334155; border-radius: 4; display: block \}"
            + " .dropdown-option \{ padding: 6 10; color: #e2e8f0; font-scale: 2; display: flex; align-items: center; border-bottom: 1px solid #334155 \}"
            + " .dropdown-option.active-option \{ background-color: #3b82f6 \}"
            // El backdrop es translúcido por el ALPHA del color (rgba), no por
            // `opacity`: opacity ahora propaga al subárbol como en la web (core
            // 9.2.6+) y lavaría la caja del modal, que es hija del backdrop.
            + " .modal-backdrop \{ display: flex; justify-content: center; align-items: center; background-color: rgba(0, 0, 0, 0.6) \}"
            + " .modal-box \{ background-color: #1e293b; border: 1px solid #334155; border-radius: 10; display: block; padding: 18; position: relative \}"
            + " .modal-header \{ display: flex; direction: row; align-items: center; justify-content: space-between; margin-bottom: 12 \}"
            + " .modal-title \{ color: #e2e8f0; font-scale: 2 \}"
            + " .modal-close \{ color: #94a3b8; font-scale: 2; padding: 4 8 \}"
            + " .modal-divider \{ background-color: #334155; height: 1; margin-bottom: 12; width: 100% \}"
            + " .Collapsible \{ display: block; margin-bottom: 12 \}"
            + " .collapsible-header \{ display: flex; direction: row; align-items: center; gap: 8; background-color: #1e293b; border: 1px solid #334155; padding: 0 10; border-radius: 4 \}"
            + " .collapsible-header.disabled-header \{ color: #475569 \}"
            + " .collapsible-chevron \{ color: #94a3b8; font-scale: 1 \}"
            + " .collapsible-title \{ color: #e2e8f0; font-scale: 2 \}"
            + " .collapsible-body \{ padding-left: 14; padding-top: 6; display: block \}"
            + " Table \{ display: block; border: 1px solid #334155; border-radius: 4; margin-bottom: 12 \}"
            + " .table-header-row \{ display: flex; direction: row; background-color: #3b82f6; color: #ffffff \}"
            + " .table-row \{ display: flex; direction: row; background-color: #1e293b; border-bottom: 1px solid #334155 \}"
            + " .table-row-alt \{ background-color: #111827 \}"
            + " .table-cell \{ padding: 6 8; color: #e2e8f0; font-scale: 2 \}"
            + " Toast \{ display: flex; align-items: center; padding: 0 12; border-radius: 6; margin-bottom: 12; background-color: #3b82f6 \}"
            + " .toast-success \{ background-color: #16a34a \}"
            + " .toast-warn \{ background-color: #d97706 \}"
            + " .toast-error \{ background-color: #dc2626 \}"
            + " .toast-message \{ color: #ffffff; font-scale: 2 \}"
            + " Chart \{ display: block; background-color: #111827; margin-bottom: 12 \}"
            + " .chart-bars-row \{ display: flex; direction: row; align-items: flex-end; padding: 8 \}"
            + " .chart-bar-col \{ display: flex; flex-direction: column; justify-content: flex-end \}"
            + " .chart-bar-fill \{ background-color: #3b82f6; border-radius: 2 \}"
            + " .chart-fallback-label \{ color: #94a3b8; font-scale: 2; padding: 12 \}"
            + " DropZone \{ display: flex; background-color: #1e293b; border: 1px solid #334155; border-radius: 4; margin-bottom: 12 \}"
            + " DropZone.files-hovering \{ border-color: #60a5fa; background-color: #1e293b \}"
            + " .dropzone-label \{ color: #94a3b8; font-scale: 2 \}"
            + " Tooltip \{ display: block \}"
            + " .tooltip-box \{ background-color: #1f2937; border: 1px solid #334155; color: #e2e8f0; font-scale: 1; padding: 4 6; border-radius: 4 \}"
            + " .FileInput \{ display: flex; direction: row; align-items: center; gap: 12; margin-bottom: 12 \}"
            + " .fileinput-button \{ background-color: #3b82f6; color: #e2e8f0; display: flex; justify-content: center; align-items: center; border-radius: 4; font-scale: 2 \}"
            + " .fileinput-button-disabled \{ background-color: #334155 \}"
            + " .fileinput-value \{ color: #94a3b8; font-scale: 2 \}"
    }

    public void renderNative(any vdom) {
        // 1) Hoja de estilo del core (cache por handle; se carga una sola vez).
        //    UA (defaults) + `.szs` del app: el app pisa al UA.
        if (this.coreSheet < 1 && this.sheet != null) {
            this.coreSheet = Gui.loadStylesheet(this.uaStyles() + " " + this.sheet.rawSource())
        }
        // 2) ctx para condiciones reactivas del core: [[nombre, texto]].
        let ctx = []
        let i = 0
        while (i < this.fullCtx.length()) {
            ctx.push([this.fullCtx[i][0], "" + this.fullCtx[i][1]])
            i = i + 1
        }
        // 3) Fuente proporcional por defecto (el core mide/dibuja con la familia activa;
        //    por-tag todavía no, eso es un hueco). Segoe UI como el intérprete.
        Gui.setFont(this.defaultFam)
        
        // Reset overlay fields
        this.hasModal = false
        this.modalNode = null
        this.focusOrd = 0
        this.modalRegStart = 0

        // Tooltip por hover: se detecta contra las regions del frame ANTERIOR (siguen
        // vigentes hasta este re-layout) y lowerTooltip pinta la cajita si coincide.
        this.hasTip = false
        this.tipText = ""
        let thi = 0
        while (thi < this.regions.length()) {
            let hr = this.regions[thi]
            if (hr[0] == "Tooltip"
                && this.mouseX >= hr[1] && this.mouseX < hr[1] + hr[3]
                && this.mouseY >= hr[2] && this.mouseY < hr[2] + hr[4]) {
                this.hasTip = true
                this.tipText = "" + hr[5].getProp("tip")
            }
            thi = thi + 1
        }

        // 4) Bajar el árbol y envolverlo en el padding de contenido (= this.pad del
        //    intérprete), para que el contenido no quede pegado al borde de la ventana.
        let inner = this.lowerVNode(vdom)
        let contentDiv = ["div", [["margin-top", "" + (0 - this.scrollY)]], [inner]]
        let treeKids = [contentDiv]

        if (this.hasModal) {
            // Las regions del modal son las últimas: su primer índice = ordinales ya
            // consumidos por el árbol principal (índice-de-region == ordinal).
            this.modalRegStart = this.focusOrd
            let overlayNode = this.lowerModalOverlay()
            treeKids.push(overlayNode)
        }

        let tree = ["div", [["padding", "" + this.pad]], treeKids]
        // min/max-width del contenido (setMaxWidth/setMinWidth): igual que el camino
        // interpretado — el contenido se acota a maxW y se CENTRA bajo la ventana.
        if (this.maxW > 0 && this.maxW < this.w) {
            // Paridad con el interpretado: la COLUMNA de contenido mide maxW y su
            // borde izquierdo cae en (w-maxW)/2; el padding queda solo vertical.
            let side = (this.w - this.maxW) / 2
            tree = ["div", [["padding-left", "" + side]],
                [["div", [["width", "" + this.maxW], ["padding-top", "" + this.pad], ["padding-bottom", "" + this.pad]], treeKids]]]
        }
        let coreRegs = Gui.renderTree(tree, this.coreSheet, this.w, this.h, ctx)
        // 4) Regions → formato de handleGuiInput: [tag,x,y,w,h, VNode]. El lowering
        //    embebe el VNode ORIGINAL en el attr `onClick` (via withRef), así el core lo
        //    devuelve en cr[5] y handleGuiInput lee TODOS sus props (onClick/onChange/
        //    value/disabled/…). SOLO se conservan las regions CON ref (interactivas):
        //    1 region por widget, en pre-orden = mismo orden en que los lowerings
        //    consumen ordinales (focusOrd) → índice de region == ordinal de foco, el
        //    mismo contrato que el intérprete. Las regions de nodos decorativos
        //    (div/span/texto) se descartan.
        this.regions = []
        let maxBottom = 0
        let ri = 0
        while (ri < coreRegs.length()) {
            let cr = coreRegs[ri]
            let bottom = cr[2] + cr[4] + this.scrollY
            if (bottom > maxBottom) { maxBottom = bottom; }

            if (cr[5] != null) {
                let rnode = null
                if (cr[5] is VNode) { rnode = cr[5] }
                else { rnode = new VNode(cr[0], [["onClick", cr[5]]], []) }
                
                let isTa = (rnode.getTag() == "Textarea")
                if (isTa) {
                    let ord = rnode.getProp("ta-ord")
                    let total = rnode.getProp("ta-total")
                    let vis = rnode.getProp("ta-vis")
                    if (ord != null && total != null && vis != null) {
                        this.regions.push([cr[0], cr[1], cr[2], cr[3], cr[4], rnode, ord, total, vis])
                    } else {
                        this.regions.push([cr[0], cr[1], cr[2], cr[3], cr[4], rnode])
                    }
                } else {
                    this.regions.push([cr[0], cr[1], cr[2], cr[3], cr[4], rnode])
                }
            }
            ri = ri + 1
        }
        // 5) Fondo de ventana desde la regla `body` (el core no la pinta: no es nodo
        //    del árbol). Reusa el resolvedor de css.sz para la condición reactiva.
        if (this.sheet != null) {
            this.bgCol = this.sheet.colorProp("body", "background-color", this.bgCol, this.fullCtx)
        }
        this.contentH = maxBottom
        this.drawScrollbarNative()
        this.drawTaScrollbarsNative()
    }

    // ── Render completo: limpia y redibuja desde la raíz ───────────────────────
    public void render(any vdom, int width, int height) {
        this.w           = width
        this.h           = height
        this.ensureFonts()   // carga las :font de la hoja (una vez)
        // Inyecta width/height en el ctx → "media queries" .szs: body (width < 600) { … }
        this.fullCtx = []
        let ci = 0
        while (ci < this.ctx.length()) { this.fullCtx.push(this.ctx[ci]); ci = ci + 1 }
        this.fullCtx.push(["width", this.w])
        this.fullCtx.push(["height", this.h])
        this.refreshStyleCache()   // invalida la caché de estilos si cambió el ctx

        // Camino NATIVO (Fase 3): delega layout+CSS+paint al core.
        if (this.native) { this.renderNative(vdom); return; }

        // Ancho de contenido acotado por min/max-width; se centra si max lo limita.
        let avail = width - this.pad * 2
        let eff   = avail
        if (this.maxW > 0 && eff > this.maxW) { eff = this.maxW; }
        if (eff < this.minW) { eff = this.minW; }
        this.cx          = this.pad
        if (eff < avail) { this.cx = (width - eff) / 2; }   // centrar bajo max-width
        this.cy          = this.pad - this.scrollY    // desplazamiento de scroll vertical
        this.colWidth    = eff
        this.regions     = []
        this.focusOrd    = 0
        this.drewCaret   = false   // ¿se dibujó un caret de texto? (para el blink/idle)
        this.hasOpenDrop = false
        this.hasModal    = false
        this.hasTip      = false
        this.taHoverIdx  = -1     // reset hover de Textarea (se detecta durante el render)
        this.bgCol = this.colorFor("body", "background-color", this.colBg)
        this.swBegin()
        this.renderNode(vdom)
        this.contentH = this.cy + this.scrollY - this.pad   // alto total del contenido
        // El overlay del dropdown abierto se pinta al final, sobre todo lo demás.
        if (this.dropOpen && this.hasOpenDrop) {
            this.drawDropdownOverlay()
        }
        this.drawScrollbar()
        // Modal y Tooltip se dibujan por ENCIMA de todo (incluida la scrollbar).
        if (this.hasModal) { this.drawModalOverlay() }
        if (this.hasTip)   { this.drawTooltipOverlay() }
        this.swEnd()   // borra los nodos de escena que este frame ya no emitió
    }

    // Barra de scroll a la derecha cuando el contenido no entra en la ventana.
    // Ahora de 14px de ancho (más fácil de clickear) y guarda las métricas para
    // que window.sz pueda hacer hit-test y click/drag.
    public void drawScrollbar() {
        if (this.contentH + this.pad <= this.h) { this.sbVisible = false; return; }
        let tw = this.sbTrackW       // 14px
        let trackX = this.w - tw
        this.sbTrackX = trackX
        this.swRect(trackX, 0, tw, this.h, this.colBorder)
        let thumbH = (this.h * this.h) / this.contentH
        if (thumbH < 32) { thumbH = 32; }
        let maxS = this.contentH + this.pad - this.h
        if (maxS < 1) { maxS = 1; }
        this.sbMaxS = maxS
        let thumbY = (this.scrollY * (this.h - thumbH)) / maxS
        this.sbThumbY = thumbY
        this.sbThumbH = thumbH
        this.sbVisible = true
        // Track: borde sutil. Thumb: color más visible, redondeado.
        let thumbX = trackX + 2
        let thumbW = tw - 4
        this.swRoundRect(thumbX, thumbY, thumbW, thumbH, 4, this.colMuted)
    }

    public void drawScrollbarNative() {
        if (this.contentH + this.pad <= this.h) { this.sbVisible = false; return; }
        let tw = this.sbTrackW       // 14px
        let trackX = this.w - tw
        this.sbTrackX = trackX
        
        let trackId = Gui.nodeRect(trackX, 0, tw, this.h, this.colBorder)
        Gui.nodeSet(trackId, "z", 100000)
        
        let thumbH = (this.h * this.h) / this.contentH
        if (thumbH < 32) { thumbH = 32; }
        let maxS = this.contentH + this.pad - this.h
        if (maxS < 1) { maxS = 1; }
        this.sbMaxS = maxS
        let thumbY = (this.scrollY * (this.h - thumbH)) / maxS
        this.sbThumbY = thumbY
        this.sbThumbH = thumbH
        this.sbVisible = true
        
        let thumbX = trackX + 2
        let thumbW = tw - 4
        let thumbId = Gui.nodeRoundRect(thumbX, thumbY, thumbW, thumbH, 4, this.colMuted)
        Gui.nodeSet(thumbId, "z", 100001)
    }

    // Barra de scroll interna de cada Textarea (camino nativo). El textbox del core
    // solo pinta las `vis` líneas visibles (el slicing lo hace lowerTextarea); acá se
    // superpone el THUMB — un overlay a la derecha de la caja, con Gui.nodeRect a z alto
    // (fuera del clip del textbox). Sin él, el textarea scrolleaba (rueda/arrastre del
    // borde derecho) pero no se veía dónde estaba. Solo thumb (sin track) para no tapar
    // el texto; cae dentro de los 24px del borde que handleGuiInput usa como área de
    // arrastre, así clickearlo también arrastra.
    public void drawTaScrollbarsNative() {
        let i = 0
        while (i < this.regions.length()) {
            let rg = this.regions[i]
            // rg = [tag,x,y,w,h,node, ord,total,vis]: solo las Textarea llevan esas 3
            // métricas extra (length > 8). El tag es "textbox" (el primitivo), no
            // "Textarea", así que se filtra por la presencia de las métricas.
            if (rg.length() > 8) {
                let ord   = rg[6]
                let total = rg[7]
                let vis   = rg[8]
                if (total > vis && vis > 0) {
                    let bx = rg[1]; let by = rg[2]; let bw = rg[3]; let bh = rg[4]
                    let tw = 6
                    let thumbX = bx + bw - tw - 3          // 3px del borde derecho
                    let thumbH = (bh * vis) / total        // proporción visible
                    if (thumbH < 24) { thumbH = 24; }
                    if (thumbH > bh) { thumbH = bh; }
                    let maxSt = total - vis
                    if (maxSt < 1) { maxSt = 1; }
                    let pos = this.getTaScroll(ord)
                    if (pos < 0) { pos = 0; }
                    if (pos > maxSt) { pos = maxSt; }
                    let thumbY = by + (pos * (bh - thumbH)) / maxSt
                    let id = Gui.nodeRoundRect(thumbX, thumbY, tw, thumbH, 3, this.colMuted)
                    Gui.nodeSet(id, "z", 99000)
                }
            }
            i = i + 1
        }
    }

    public void renderNode(any node) {
        if (node == null) { return; }

        let isPrim = node is string || node is int || node is decimal || node is bool
        if (isPrim) {
            this.drawWrapped("", "" + node, 2, this.colText, 6)
            return
        }

        let tag      = node.getTag()
        if (this.strProp(tag, "display", "block") == "none") { return; }   // .szs: ocultar
        this.cy = this.cy + this.numProp(tag, "margin-top", 0)             // .szs: espacio arriba
        let children = node.getChildren()

        if (tag == "h1") {
            let sc1 = this.numProp("h1", "font-scale", 3)
            this.drawWrapped("h1", this.collectText(node), sc1, this.colorFor("h1", "color", this.colText), 12)

        } else if (tag == "h2") {
            let sc2 = this.numProp("h2", "font-scale", 2)
            this.drawWrapped("h2", this.collectText(node), sc2, this.colorFor("h2", "color", this.colText), 10)

        } else if (tag == "p" || tag == "span" || tag == "h3" || tag == "li") {
            let scp = this.numProp(tag, "font-scale", 2)
            this.drawWrapped(tag, this.collectText(node), scp, this.colorFor(tag, "color", this.colMuted), 8)

        } else if (tag == "hr") {
            this.swLine(this.cx, this.cy, this.cx + this.colWidth, this.cy, this.colorFor("hr", "color", this.colBorder))
            this.cy = this.cy + 14

        } else if (tag == "Button") {
            this.renderButton(node)
        } else if (tag == "FileInput") {
            this.renderFileInput(node)
        } else if (tag == "Input") {
            this.renderInput(node)
        } else if (tag == "Select") {
            this.renderSelect(node)
        } else if (tag == "Checkbox") {
            this.renderCheckbox(node)
        } else if (tag == "Switch" || tag == "Toggle") {
            this.renderSwitch(node)
        } else if (tag == "Tabs") {
            this.renderTabs(node)
        } else if (tag == "Collapsible" || tag == "Accordion") {
            this.renderCollapsible(node)
        } else if (tag == "Textarea") {
            this.renderTextarea(node)
        } else if (tag == "RadioGroup") {
            this.renderRadioGroup(node)
        } else if (tag == "Slider") {
            this.renderSlider(node)
        } else if (tag == "ProgressBar") {
            this.renderProgressBar(node)
        } else if (tag == "Chart") {
            this.renderChart(node)
        } else if (tag == "DropZone") {
            this.renderDropZone(node)
        } else if (tag == "Dropdown") {
            this.renderDropdown(node)
        } else if (tag == "Label") {
            this.renderLabel(node)
        } else if (tag == "Link") {
            this.renderLink(node)
        } else if (tag == "Image") {
            this.renderImage(node)
        } else if (tag == "Table") {
            this.renderTable(node)
        } else if (tag == "Toast") {
            this.renderToast(node)
        } else if (tag == "Modal") {
            this.renderModal(node)
        } else if (tag == "Tooltip") {
            this.renderTooltip(node)
        } else if (tag == "Row") {
            this.renderRow(node)
        } else {
            // div, Col, section, form, ul, __fragment__ — contenedores verticales (con padding)
            let pad = this.numProp(tag, "padding", 0)
            let savedCx = this.cx
            let savedCW = this.colWidth
            this.cx       = this.cx + pad
            this.cy       = this.cy + pad
            this.colWidth = this.colWidth - pad * 2
            let i = 0
            while (i < children.length()) {
                this.renderNode(children[i])
                i = i + 1
            }
            this.cx       = savedCx
            this.colWidth = savedCW
            this.cy       = this.cy + pad
        }
        this.cy = this.cy + this.numProp(tag, "margin-bottom", 0)   // .szs: espacio extra abajo
    }

    // ── Anillo de foco (4 barras finas alrededor del rect) ─────────────────────
    public void drawFocusRing(int bx, int by, int bw, int bh) {
        let c = this.colFocus
        this.swRect(bx - 2, by - 2, bw + 4, 2, c)
        this.swRect(bx - 2, by + bh, bw + 4, 2, c)
        this.swRect(bx - 2, by - 2, 2, bh + 4, c)
        this.swRect(bx + bw, by - 2, 2, bh + 4, c)
    }

    // Triángulo lleno apuntando hacia abajo (▼): base arriba (ancho 2*half+1) que
    // converge a un punto abajo. Para la flecha del Dropdown (no la letra "v").
    public void drawTriDown(int cx, int topY, int half, int color) {
        let row = 0
        while (row <= half) {
            let w = (half - row) * 2 + 1
            this.swRect(cx - (half - row), topY + row, w, 1, color)
            row = row + 1
        }
    }

    // ── Button ─────────────────────────────────────────────────────────────────
    public void renderButton(any node) {
        let label    = this.collectText(node)
        let fam      = this.setFam("Button")
        let m        = Gui.measureText(label, 2)
        let bw       = m[0] + 28
        let bh       = 40
        let bx       = this.cx
        let by       = this.cy
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let hover = this.mouseX >= bx && this.mouseX < bx + bw && this.mouseY >= by && this.mouseY < by + bh
        let color = this.colorFor("Button", "background-color", this.colBtn)
        if (disabled) {
            color = this.colBorder
        } else if (hover && this.mouseHeld) {
            color = this.colBtnDn
        } else if (hover) {
            color = this.colBtnHov
        }

        this.fillBox("Button", bx, by, bw, bh, color)
        this.swText(bx + 14, by + 12, label, 2, this.colorFor("Button", "color", this.colText))
        if (fam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, bw, bh) }

        this.regions.push(["Button", bx, by, bw, bh, node])
        this.lastW = bw
        this.cy = this.cy + bh + 10
    }

    // ── FileInput (botón "Elegir archivo…" + nombre del elegido) ───────────────
    // El click abre Gui.openFileDialog (lo maneja window.sz::openFilePicker).
    public void renderFileInput(any node) {
        let label = node.getProp("label")
        if (label == null) { label = "Elegir archivo..."; }
        let value = node.getProp("value")
        let placeholder = node.getProp("placeholder")
        if (placeholder == null) { placeholder = "Ningun archivo"; }
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let bh = 40

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        // Botón (izquierda) — mismo estilo que Button.
        let fam   = this.setFam("Button")
        let m     = Gui.measureText(label, 2)
        let btnW  = m[0] + 28
        let hover = this.mouseX >= bx && this.mouseX < bx + btnW && this.mouseY >= by && this.mouseY < by + bh
        let color = this.colorFor("Button", "background-color", this.colBtn)
        if (disabled) { color = this.colBorder }
        else if (hover && this.mouseHeld) { color = this.colBtnDn }
        else if (hover) { color = this.colBtnHov }
        this.fillBox("Button", bx, by, btnW, bh, color)
        this.swText(bx + 14, by + 12, label, 2, this.colorFor("Button", "color", this.colText))
        if (fam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, btnW, bh) }

        // Nombre del archivo elegido (derecha), o el placeholder si no hay.
        // Texto no editable → fuente PROPORCIONAL (si no, caería a la rejilla mono).
        let shown    = placeholder
        let shownCol = this.colMuted
        if (value != null && ("" + value) != "") {
            shown = this.baseName("" + value)
            shownCol = this.colText
        }
        let sfam = this.setFam("body")
        this.swText(bx + btnW + 12, by + 12, shown, 2, shownCol)
        if (sfam) { this.swSetFont(""); }

        // La región cubre solo el botón (el click abre el diálogo).
        this.regions.push(["FileInput", bx, by, btnW, bh, node])
        this.cy = this.cy + bh + 10
    }

    // Nombre de archivo desde una ruta (última parte tras '/' o '\').
    public string baseName(string path) {
        let last = 0
        let i = 0
        while (i < path.length()) {
            let ch = path.charAt(i)
            if (ch == "/" || ch == "\\") { last = i + 1; }
            i = i + 1
        }
        return path.substring(last, path.length())
    }

    // ── Input (una línea, con cursor y recorte horizontal) ─────────────────────
    public void renderInput(any node) {
        let val         = node.getProp("value")
        let placeholder = node.getProp("placeholder")
        let type        = node.getProp("type")
        let disabled    = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        let bh = 34
        let scale = 2
        // Fuente del campo: si la hoja define Input { font-family } (monoespaciada),
        // se activa y el ancho de celda se MIDE; si no, la rejilla 8x8 por defecto.
        let fam = this.setMonoFam("Input")
        let charW = 8 * scale
        if (fam) { charW = Gui.measureText("M", scale)[0]; if (charW < 1) { charW = 8 * scale; } }

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let ibg  = this.colorFor("Input", "background-color", this.colInput)
        let bcol = this.colBorder
        if (focused) { bcol = this.colFocus }
        let irad = this.numProp("Input", "border-radius", 0)
        if (irad > 0) {
            this.swRoundRect(bx, by, bw, bh, irad, bcol)
            let ir2 = irad - 2
            if (ir2 < 1) { ir2 = 1; }
            this.swRoundRect(bx + 2, by + 2, bw - 4, bh - 4, ir2, ibg)
        } else {
            this.swRect(bx, by, bw, bh, ibg)
            this.swRectOutline(bx, by, bw, bh, bcol)
        }

        // String visible (enmascarado si password)
        let raw = ""
        if (val != null) { raw = "" + val }
        let display = raw
        if (type == "password") {
            let masked = ""
            let k = 0
            while (k < raw.length()) { masked = masked + "*"; k = k + 1; }
            display = masked
        }

        let textX = bx + 10
        // Cuántos caracteres caben (monoespaciado): cuenta sin división dudosa
        let fit = 0
        let acc = textX
        while (acc + charW <= bx + bw - 10) { fit = fit + 1; acc = acc + charW; }

        let car = this.caret
        if (car > display.length()) { car = display.length(); }
        if (car < 0) { car = 0; }

        // Desplazamiento para mantener el cursor a la vista
        let start = 0
        if (focused && car > fit) { start = car - fit; }

        // Resaltado de selección (rango [lo, hi) acotado a la ventana visible).
        if (focused && this.selAnchor >= 0 && this.selAnchor != car) {
            let lo = car
            let hi = car
            if (this.selAnchor < car) { lo = this.selAnchor; } else { hi = this.selAnchor; }
            let vlo = lo - start; if (vlo < 0) { vlo = 0; }
            let vhi = hi - start; if (vhi > fit) { vhi = fit; }
            if (vhi > vlo) {
                this.swRectAlpha(textX + vlo * charW, by + 7, (vhi - vlo) * charW, bh - 14, this.colFocus, 110)
            }
        }

        let tcol = this.colorFor("Input", "color", this.colText)
        if (display.length() == 0 && placeholder != null) {
            // Placeholder en fuente PROPORCIONAL (texto no editable → sin caret math):
            // se ve moderno aunque el campo sea monoespaciado. El caret vacío queda en
            // textX (posición 0), así que no hay desalineación.
            if (fam) { this.swSetFont(""); }
            let pfam = this.setFam("body")
            this.swText(textX, by + 9, "" + placeholder, scale, this.colMuted)
            if (pfam) { this.swSetFont(""); }
            if (fam) { this.setMonoFam("Input"); }
        } else {
            let endIdx = start + fit
            if (endIdx > display.length()) { endIdx = display.length(); }
            let shown = display.substring(start, endIdx)
            this.swText(textX, by + 9, shown, scale, tcol)
        }

        // Caret solo si el campo Y la ventana tienen foco: un Input enfocado de una
        // ventana en segundo plano no parpadea (winFocused = Gui.focused).
        if (focused && this.winFocused) {
            this.drewCaret = true   // hay caret → el loop anima el blink
            let cpos = car - start
            if (cpos < 0) { cpos = 0; }
            let caretX = textX + cpos * charW
            // Composición IME en curso (CJK): se pinta subrayada justo en el caret.
            let pre = this.imePreedit
            if (pre != null && pre != "") {
                this.swText(caretX, by + 9, "" + pre, scale, tcol, 4)
                caretX = caretX + pre.length() * charW
            }
            // blink: visible 700ms, oculto 300ms
            if (Gui.time() % 1000 < 700) {
                this.swRect(caretX, by + 7, 2, bh - 14, this.colText)
            }
            Gui.setImePosition(caretX, by + 7)
        }

        if (fam) { this.swSetFont(""); }
        // Región con metadata extra para el hit-test del caret: charW (avance real,
        // medido para la fuente del campo), textX (inicio del texto) y start (offset
        // de scroll horizontal). caretFromClick los usa para mapear x→carácter.
        this.regions.push(["Input", bx, by, bw, bh, node, charW, textX, start])
        this.cy = this.cy + bh + 12
    }

    // ── Select (clic cicla; ←/→ con foco) ──────────────────────────────────────
    public void renderSelect(any node) {
        let value    = node.getProp("value")
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        let bh = 34

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let hover = this.mouseX >= bx && this.mouseX < bx + bw && this.mouseY >= by && this.mouseY < by + bh
        let color = this.colorFor("Select", "background-color", this.colInput)
        if (!disabled && hover && this.mouseHeld) {
            color = this.colBtnDn
        } else if (!disabled && hover) {
            color = this.colBtnHov
        }
        this.fillBox("Select", bx, by, bw, bh, color)

        let display = "" + value
        if (disabled) { display = "  " + display + "  "; }
        else { display = "< " + display + " >"; }
        let sfam = this.setFam("Select")
        this.swText(bx + 10, by + 9, display, 2, this.colorFor("Select", "color", this.colText))
        if (sfam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, bw, bh) }

        this.regions.push(["Select", bx, by, bw, bh, node])
        this.cy = this.cy + bh + 12
    }

    // ── Checkbox ────────────────────────────────────────────────────────────────
    public void renderCheckbox(any node) {
        let checked = node.getProp("checked") == true
        let label   = node.getProp("label")
        if (label == null) { label = this.collectText(node); }
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let boxSize = 20

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let cfam  = this.setFam("Checkbox")
        let lm    = Gui.measureText("" + label, 2)
        let regW  = boxSize + 8 + lm[0]
        let hover = this.mouseX >= bx && this.mouseX < bx + regW && this.mouseY >= by && this.mouseY < by + boxSize

        let color = this.colorFor("Checkbox", "background-color", this.colInput)
        if (!disabled && hover && this.mouseHeld) {
            color = this.colBtnDn
        } else if (!disabled && hover) {
            color = this.colBtnHov
        }
        this.swRect(bx, by, boxSize, boxSize, color)
        if (checked) {
            this.swText(bx + 4, by + 4, "X", 2, this.colorFor("Checkbox", "color", this.colText))
        }
        this.swText(bx + boxSize + 8, by + 2, "" + label, 2, this.colorFor("Checkbox", "color", this.colText))
        if (cfam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, regW, boxSize); }

        this.regions.push(["Checkbox", bx, by, regW, boxSize, node])
        this.lastW = regW
        this.cy = this.cy + boxSize + 12
    }

    // ── Switch / Toggle (pill con knob deslizante; misma semántica que Checkbox) ─
    public void renderSwitch(any node) {
        let checked  = node.getProp("checked") == true
        let label    = node.getProp("label")
        if (label == null) { label = this.collectText(node); }
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let trackW = 44
        let trackH = 22
        let knobR  = 8

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let sfam = this.setFam("Switch")
        let lm   = Gui.measureText("" + label, 2)
        let regW = trackW + 8 + lm[0]
        let hover = this.mouseX >= bx && this.mouseX < bx + regW && this.mouseY >= by && this.mouseY < by + trackH

        // Track (pill redondeado): acento si ON, borde si OFF.
        let track = this.colBorder
        if (checked) { track = this.colorFor("Switch", "background-color", this.colBtn); }
        if (disabled) { track = this.colBorder; }
        else if (checked && hover) { track = this.colBtnHov; }
        this.swRoundRect(bx, by, trackW, trackH, trackH / 2, track)

        // Knob (círculo): izquierda (OFF) o derecha (ON).
        let knobCx = bx + knobR + 3
        if (checked) { knobCx = bx + trackW - knobR - 3; }
        let knobCy  = by + trackH / 2
        let knobCol = this.colText
        if (disabled) { knobCol = this.colMuted; }
        this.swCircle(knobCx, knobCy, knobR, knobCol)

        // Etiqueta a la derecha (si hay).
        if (("" + label) != "") {
            this.swText(bx + trackW + 8, by + 3, "" + label, 2, this.colorFor("Switch", "color", this.colText))
        }
        if (sfam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, regW, trackH); }

        this.regions.push(["Switch", bx, by, regW, trackH, node])
        this.lastW = regW
        this.cy = this.cy + trackH + 12
    }

    // ── Tabs (barra de pestañas; la app renderiza el contenido según `active`) ──
    // Controlado: props tabs (array de labels), active (int), onChange (fn(idx)).
    // La región guarda los límites-x de cada pestaña (campo 6) para mapear el clic.
    public void renderTabs(any node) {
        let tabs = node.getProp("tabs")
        if (tabs == null) { tabs = []; }
        let active = node.getProp("active")
        if (active == null) { active = 0; }
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let barH = 34

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        // Línea inferior a lo ancho (el subrayado del activo se dibuja encima).
        this.swRect(bx, by + barH - 1, this.colWidth, 1, this.colBorder)

        let tfam = this.setFam("Tabs")
        let accent = this.colorFor("Tabs", "background-color", this.colBtn)
        let bounds = []
        let padX = 14
        let x = bx
        let i = 0
        while (i < tabs.length()) {
            let label = "" + tabs[i]
            let tw    = Gui.measureText(label, 2)[0] + padX * 2
            let isAct = (i == active)
            let hover = this.mouseX >= x && this.mouseX < x + tw && this.mouseY >= by && this.mouseY < by + barH
            if (isAct) { this.swRect(x, by, tw, barH - 1, this.colInput); }
            else if (!disabled && hover) { this.swRect(x, by, tw, barH - 1, this.colInput); }
            let tcol = this.colMuted
            if (isAct) { tcol = this.colorFor("Tabs", "color", this.colText); }
            else if (!disabled && hover) { tcol = this.colText; }
            this.swText(x + padX, by + 9, label, 2, tcol)
            if (isAct) { this.swRect(x, by + barH - 3, tw, 3, accent); }   // subrayado del activo
            x = x + tw
            bounds.push(x)
            i = i + 1
        }
        if (tfam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, x - bx, barH); }

        this.regions.push(["Tabs", bx, by, x - bx, barH, node, bounds])
        this.lastW = x - bx
        this.cy = this.cy + barH + 10
    }

    // ── Collapsible / Accordion (sección plegable: header clickeable + children) ─
    // Controlado: props title, open (bool), onToggle(fn(bool)). Cuando open, dibuja
    // los children (contenido rico) indentados debajo del header.
    public void renderCollapsible(any node) {
        let title = node.getProp("title")
        if (title == null) { title = ""; }
        let open  = node.getProp("open") == true
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let headH = 32
        let hw = this.colWidth

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let hover = this.mouseX >= bx && this.mouseX < bx + hw && this.mouseY >= by && this.mouseY < by + headH
        let hbg = this.colorFor("Collapsible", "background-color", this.colInput)
        if (!disabled && hover) { hbg = this.colBtnHov; }
        this.fillBox("Collapsible", bx, by, hw, headH, hbg)

        // Chevron (triángulo): derecha si cerrado, abajo si abierto.
        let tcol = this.colorFor("Collapsible", "color", this.colText)
        let cx0 = bx + 12
        let cy0 = by + headH / 2
        if (open) {
            this.swPolygon([cx0 - 5, cy0 - 3, cx0 + 5, cy0 - 3, cx0, cy0 + 4], tcol)
        } else {
            this.swPolygon([cx0 - 3, cy0 - 5, cx0 - 3, cy0 + 5, cx0 + 4, cy0], tcol)
        }

        let cfam = this.setFam("Collapsible")
        this.swText(bx + 28, by + 8, "" + title, 2, tcol)
        if (cfam) { this.swSetFont(""); }
        if (focused) { this.drawFocusRing(bx, by, hw, headH); }

        this.regions.push(["Collapsible", bx, by, hw, headH, node])
        this.cy = this.cy + headH + 4

        // Contenido (children) cuando está abierto — indentado.
        if (open) {
            let savedCx = this.cx
            let savedCW = this.colWidth
            this.cx = this.cx + 14
            this.colWidth = this.colWidth - 14
            let children = node.getChildren()
            let i = 0
            while (i < children.length()) {
                this.renderNode(children[i])
                i = i + 1
            }
            this.cx = savedCx
            this.colWidth = savedCW
        }
        this.cy = this.cy + 6
    }

    // ── Textarea (multilínea con AJUSTE de línea + recorte a la caja) ──────────
    // El texto se parte en "segmentos visuales" (cada línea lógica \n se corta cada
    // `maxCols` caracteres, preservando los caracteres EXACTOS — sin colapsar espacios —
    // para que los offsets cuadren con el string plano del caret/selección). Todo se
    // dibuja dentro de un clip a la caja, así NADA se desborda por los bordes.
    //   rows  = alto fijo en líneas visibles.
    //   grow  = true → la caja crece hasta el contenido (con tope) y el scroll de
    //           página muestra el resto (ideal para el cuerpo de una respuesta).
    public void renderTextarea(any node) {
        let val         = node.getProp("value")
        let placeholder = node.getProp("placeholder")
        let rows        = node.getProp("rows")
        let disabled    = node.getProp("disabled") == true
        let grow        = node.getProp("grow") == true
        if (rows == null) { rows = 4; }
        if (val == null) { val = ""; }
        if (type_of(val) != "string") { val = "" + val; }

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        // Tamaño respeta font-scale del .szs (antes fijo a 1 = 8px, se veía diminuto).
        let scale = this.numProp("Textarea", "font-scale", 1)
        let lineH = 12 * scale + 6
        // Fuente del campo (monoespaciada propia, sin heredar body); ancho medido.
        let fam = this.setMonoFam("Textarea")
        let charW = 8 * scale
        if (fam) { charW = Gui.measureText("M", scale)[0]; if (charW < 1) { charW = 8 * scale; } }

        // Columnas que entran (monoespaciada → exacto; int/int = división entera).
        let maxCols = (bw - 12) / charW
        if (maxCols < 1) { maxCols = 1; }

        // Índice de foco para este Textarea (necesario antes del caché de segmentos).
        let myOrd  = this.focusOrd
        this.focusOrd = this.focusOrd + 1

        // Segmentos visuales con su offset de inicio en el string plano.
        // CACHÉ: si el valor y maxCols no cambiaron desde el último render,
        // reutilizar los arrays sin re-splitear (O(1) en vez de O(n) por frame).
        let segStart = []
        let segText  = []
        let cacheHit = false
        let ci = 0
        while (ci < this.taSegCacheOrd.length()) {
            if (this.taSegCacheOrd[ci] == myOrd) {
                // Hot path: si el vdom NO cambió (scroll/blink), el valor y maxCols de este
                // Textarea son idénticos al frame previo → reusar sin comparar el string entero.
                let valid = !this.vdomDirty
                if (!valid) {
                    // Frame con vdom nuevo: rechazo barato (cols + length) antes del compare O(n).
                    valid = this.taSegCacheCols[ci] == maxCols
                         && this.taSegCacheLen[ci] == val.length()
                         && this.taSegCacheVal[ci] == val
                }
                if (valid) {
                    segStart = this.taSegCacheStart[ci]
                    segText  = this.taSegCacheText[ci]
                    cacheHit = true
                }
                ci = this.taSegCacheOrd.length()  // salir
            } else { ci = ci + 1 }
        }
        if (!cacheHit) {
            let paras = val.split("\n")
            let flat  = 0
            let pi = 0
            while (pi < paras.length()) {
                let para = paras[pi]
                if (para.length() == 0) {
                    segStart.push(flat); segText.push("")
                } else {
                    let off = 0
                    while (off < para.length()) {
                        let end = off + maxCols
                        if (end > para.length()) { end = para.length(); }
                        segStart.push(flat + off)
                        segText.push(para.substring(off, end))
                        off = end
                    }
                }
                flat = flat + para.length() + 1
                pi = pi + 1
            }
            // Guardar en caché (actualizar si existe, sino push).
            let found = false
            let ui = 0
            while (ui < this.taSegCacheOrd.length()) {
                if (this.taSegCacheOrd[ui] == myOrd) {
                    this.taSegCacheVal[ui]   = val
                    this.taSegCacheLen[ui]   = val.length()
                    this.taSegCacheCols[ui]  = maxCols
                    this.taSegCacheStart[ui] = segStart
                    this.taSegCacheText[ui]  = segText
                    found = true
                    ui = this.taSegCacheOrd.length()
                } else { ui = ui + 1 }
            }
            if (!found) {
                this.taSegCacheOrd.push(myOrd)
                this.taSegCacheVal.push(val)
                this.taSegCacheLen.push(val.length())
                this.taSegCacheCols.push(maxCols)
                this.taSegCacheStart.push(segStart)
                this.taSegCacheText.push(segText)
            }
        }

        // Alto: fijo a `rows`, o crece hasta el contenido (con tope) si grow.
        let visRows = rows
        if (grow) {
            visRows = segText.length()
            if (visRows < 1) { visRows = 1; }
            if (visRows > 40) { visRows = 40; }   // tope para no crecer sin límite
        }
        let bh = visRows * lineH + 12

        let focused = myOrd == this.focus && !disabled

        let tbg  = this.colorFor("Textarea", "background-color", this.colInput)
        let bcol = this.colBorder
        if (focused) { bcol = this.colFocus; }
        let trad = this.numProp("Textarea", "border-radius", 0)
        if (trad > 0) {
            this.swRoundRect(bx, by, bw, bh, trad, bcol)
            let tr2 = trad - 2
            if (tr2 < 1) { tr2 = 1; }
            this.swRoundRect(bx + 2, by + 2, bw - 4, bh - 4, tr2, tbg)
        } else {
            this.swRect(bx, by, bw, bh, tbg)
            this.swRectOutline(bx, by, bw, bh, bcol)
        }

        // Detectar si el mouse está sobre este Textarea (para scroll por rueda).
        let mxH = this.mouseX >= bx && this.mouseX < bx + bw && this.mouseY >= by && this.mouseY < by + bh
        if (mxH) { this.taHoverIdx = this.regions.length(); }  // será el siguiente push

        // ¿Hay contenido que excede las filas visibles? → necesita scroll interno.
        let totalSegs = segText.length()
        let needsScroll = totalSegs > visRows

        // Scroll interno: leer/acotar el startSeg guardado para este Textarea.
        let startSeg = 0
        if (needsScroll) {
            startSeg = this.getTaScroll(myOrd)
            let maxStart = totalSegs - visRows
            if (maxStart < 0) { maxStart = 0; }
            if (startSeg > maxStart) { startSeg = maxStart;
                this.setTaScroll(myOrd, startSeg);
            }
        }

        if (val.length() == 0 && placeholder != null) {
            // Placeholder en fuente PROPORCIONAL (no editable): look moderno aunque el
            // Textarea sea monoespaciado. El caret vacío queda en el origen, sin desalinear.
            if (fam) { this.swSetFont(""); }
            let pfam = this.setFam("body")
            this.swText(bx + 6, by + 6, "" + placeholder, scale, this.colMuted)
            if (pfam) { this.swSetFont(""); }
            if (fam) { this.setMonoFam("Textarea"); }
        } else {
            // Caret (offset plano) → línea/columna VISUAL localizando su segmento.
            let car = this.caret
            if (car > val.length()) { car = val.length(); }
            if (car < 0) { car = 0; }
            let dl = 0
            let dc = 0
            let found = false
            let low = 0
            let high = segStart.length() - 1
            while (low <= high) {
                let mid = (low + high) / 2
                let s = segStart[mid]
                let e = s + segText[mid].length()
                if (car >= s && car <= e) {
                    dl = mid; dc = car - s; found = true
                    // En un corte por ajuste (no por \n) el final de un segmento coincide
                    // con el inicio del siguiente → el caret salta al renglón siguiente.
                    if (car == e && mid + 1 < segStart.length() && segStart[mid + 1] == e) { dl = mid + 1; dc = 0; }
                    low = high + 1  // salir del loop
                } else if (car < s) {
                    high = mid - 1
                } else {
                    low = mid + 1
                }
            }
            if (!found) { dl = segText.length() - 1; if (dl < 0) { dl = 0; } dc = segText[dl].length(); }

            // Scroll vertical para mantener el cursor visible (enfocado: sigue al caret SOLO si se movió).
            let lastCar = this.getTaLastCar(myOrd)
            let caretMoved = car != lastCar
            if (focused && caretMoved) {
                if (dl < startSeg) { startSeg = dl; this.setTaScroll(myOrd, startSeg); }
                if (dl >= startSeg + visRows) { startSeg = dl - visRows + 1; this.setTaScroll(myOrd, startSeg); }
                this.setTaLastCar(myOrd, car)
            }

            // Selección: rango [selLo, selHi) sobre el string plano.
            let hasSel = focused && this.selAnchor >= 0 && this.selAnchor != car
            let selLo = car
            let selHi = car
            if (hasSel) {
                if (this.selAnchor < car) { selLo = this.selAnchor; } else { selHi = this.selAnchor; }
            }

            let tcol  = this.colorFor("Textarea", "color", this.colText)
            this.swClipPush(bx + 2, by + 2, bw - 4, bh - 4)
            let li    = startSeg
            let yrow  = by + 6
            let drawn = 0
            while (li < segText.length() && drawn < visRows) {
                let s = segStart[li]
                let segLen = segText[li].length()
                if (hasSel) {
                    let a = selLo; if (a < s) { a = s; }
                    let bsel = selHi; if (bsel > s + segLen) { bsel = s + segLen; }
                    if (bsel > a) {
                        this.swRectAlpha(bx + 6 + (a - s) * charW, yrow - 1, (bsel - a) * charW, lineH - 2, this.colFocus, 110)
                    }
                }
                this.swText(bx + 6, yrow, segText[li], scale, tcol)
                yrow  = yrow + lineH
                li    = li + 1
                drawn = drawn + 1
            }

            if (focused && this.winFocused) {
                this.drewCaret = true   // hay caret → el loop anima el blink
                let crow = by + 6 + (dl - startSeg) * lineH
                let caretPx = bx + 6 + dc * charW
                // Composición IME en curso (CJK): subrayada justo en el caret.
                let pre = this.imePreedit
                if (pre != null && pre != "") {
                    this.swText(caretPx, crow, "" + pre, scale, tcol, 4)
                    caretPx = caretPx + pre.length() * charW
                }
                if (Gui.time() % 1000 < 700) {
                    this.swRect(caretPx, crow, 1, lineH - 2, this.colText)
                }
                Gui.setImePosition(caretPx, crow)
            }

            // Mini-scrollbar interna a la derecha de la caja (si hay contenido que no entra).
            if (needsScroll) {
                let sbW   = 12
                let sbX   = bx + bw - sbW - 2
                let sbH   = bh - 8
                let sbY   = by + 4
                let stH   = (visRows * sbH) / totalSegs
                if (stH < 20) { stH = 20; }
                let maxSt = totalSegs - visRows
                if (maxSt < 1) { maxSt = 1; }
                let stY   = sbY + (startSeg * (sbH - stH)) / maxSt
                this.swRectAlpha(sbX, sbY, sbW, sbH, this.colBorder, 50)
                this.swRoundRect(sbX + 2, stY, sbW - 4, stH, (sbW - 4)/2, this.colMuted)
            }
            this.swClipPop()
        }

        if (fam) { this.swSetFont(""); }
        // Region extendida: [tag, x, y, w, h, node, taOrd, totalSegs, visRows]
        this.regions.push(["Textarea", bx, by, bw, bh, node, myOrd, totalSegs, visRows])
        this.cy = this.cy + bh + 12
    }

    // ── RadioGroup (lista de opciones excluyentes) ─────────────────────────────
    public void renderRadioGroup(any node) {
        let value    = node.getProp("value")
        let options  = node.getProp("options")
        let disabled = node.getProp("disabled") == true
        if (options == null) { options = []; }

        let bx     = this.cx
        let startY = this.cy
        let lineH  = 26

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let rfam = this.setFam("RadioGroup")
        let i = 0
        while (i < options.length()) {
            let oy  = startY + i * lineH
            let opt = options[i]
            let selected = ("" + opt) == ("" + value)
            this.swCircle(bx + 10, oy + 11, 9, this.colBorder)    // contorno (radio 9)
            this.swCircle(bx + 10, oy + 11, 7, this.colInput)     // interior (radio 7)
            if (selected) { this.swCircle(bx + 10, oy + 11, 4, this.colBtn); }   // punto
            this.swText(bx + 26, oy + 4, "" + opt, 2, this.colText)
            i = i + 1
        }
        if (rfam) { this.swSetFont(""); }

        let totalH = options.length() * lineH
        if (totalH == 0) { totalH = lineH; }
        if (focused) { this.drawFocusRing(bx, startY, this.colWidth, totalH); }

        this.regions.push(["RadioGroup", bx, startY, this.colWidth, totalH, node])
        this.cy = startY + totalH + 10
    }

    // ── Slider (pista + tirador + valor) ───────────────────────────────────────
    public void renderSlider(any node) {
        let value    = node.getProp("value")
        let min      = node.getProp("min")
        let max      = node.getProp("max")
        let disabled = node.getProp("disabled") == true
        if (min == null) { min = 0; }
        if (max == null) { max = 100; }
        if (value == null) { value = min; }

        let bx = this.cx
        let by = this.cy
        let bh = 30
        let trackW = this.colWidth - 56

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let span = max - min
        if (span <= 0) { span = 1; }
        let rel = value - min
        if (rel < 0) { rel = 0; }
        if (rel > span) { rel = span; }
        let filled = (rel * trackW) / span
        let knobX  = bx + filled

        let tyv = by + 13
        this.swRect(bx, tyv, trackW, 4, this.colBorder)
        this.swRect(bx, tyv, filled, 4, this.colBtn)
        this.swRect(knobX - 5, by + 5, 10, 18, this.colBtn)
        this.swText(bx + trackW + 12, by + 7, "" + value, 2, this.colText)
        if (focused) { this.drawFocusRing(bx, by, this.colWidth, bh); }

        this.regions.push(["Slider", bx, by, trackW, bh, node])
        this.cy = this.cy + bh + 12
    }

    // ── ProgressBar (no interactivo) ───────────────────────────────────────────
    public void renderProgressBar(any node) {
        let value = node.getProp("value")
        let max   = node.getProp("max")
        let label = node.getProp("label")
        if (value == null) { value = 0; }
        if (max == null) { max = 100; }

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        let bh = 22

        let span = max
        if (span <= 0) { span = 1; }
        let v = value
        if (v < 0) { v = 0; }
        if (v > span) { v = span; }

        this.fillBox("ProgressBar", bx, by, bw, bh, this.colInput)
        this.fillBox("ProgressBar", bx, by, (v * bw) / span, bh, this.colBtn)
        if (label != null) { this.swText(bx + 8, by + 4, "" + label, 1, this.colText); }
        this.cy = this.cy + bh + 12
    }

    // ── Chart (serie numérica dibujada con las primitivas vectoriales del core) ──
    // No interactivo (no entra en el orden de foco). type: "line"|"area"|"bar".
    public void renderChart(any node) {
        let data = node.getProp("data")
        if (data == null) { data = []; }
        let ctype = node.getProp("type")
        if (ctype == null) { ctype = "line"; }
        let bh = node.getProp("height")
        if (bh == null) { bh = 160; }

        let col = this.colorFor("Chart", "color", this.colBtn)
        let ucol = node.getProp("color")
        if (ucol != null) { col = ucol; }

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth

        // Caja de fondo (respeta CSS de Chart: background/border).
        this.fillBox("Chart", bx, by, bw, bh, this.colInput)

        let n = data.length()
        if (n == 0) {
            this.swText(bx + 10, by + bh / 2 - 6, "sin datos", 1, this.colMuted)
            this.cy = this.cy + bh + 12
            return
        }

        // Rango Y: explícito (min/max) o automático (mín/máx de la serie).
        let ymin = node.getProp("min")
        let ymax = node.getProp("max")
        if (ymin == null || ymax == null) {
            let lo = data[0]
            let hi = data[0]
            let k = 1
            while (k < n) {
                if (data[k] < lo) { lo = data[k]; }
                if (data[k] > hi) { hi = data[k]; }
                k = k + 1
            }
            if (ymin == null) { ymin = lo; }
            if (ymax == null) { ymax = hi; }
        }
        let span = ymax - ymin
        if (span <= 0) { span = 1; }

        // Área de dibujo con padding interno.
        let plotX = bx + 6
        let plotY = by + 8
        let plotW = bw - 12
        let plotH = bh - 16
        if (plotW < 1) { plotW = 1; }
        if (plotH < 1) { plotH = 1; }

        // Baseline: en el valor 0 si está en rango; si no, en el borde más cercano.
        // El `* 1.0` fuerza división decimal (mapeo exacto aunque los datos sean int).
        let baseVal = 0
        if (ymin > 0) { baseVal = ymin; }
        if (ymax < 0) { baseVal = ymax; }
        let baseY = plotY + plotH - Math.round((baseVal - ymin) * 1.0 * plotH / span)
        this.swLine(plotX, baseY, plotX + plotW, baseY, this.colBorder)

        if (ctype == "bar") {
            let slot = plotW / n
            if (slot < 1) { slot = 1; }
            let gap = slot / 6
            let i = 0
            while (i < n) {
                let vy = plotY + plotH - Math.round((data[i] - ymin) * 1.0 * plotH / span)
                let barX = plotX + i * slot + gap
                let barW = slot - gap * 2
                if (barW < 1) { barW = 1; }
                let top = vy
                let hgt = baseY - vy
                if (hgt < 0) { top = baseY; hgt = vy - baseY; }
                if (hgt < 1) { hgt = 1; }
                this.swRect(barX, top, barW, hgt, col)
                i = i + 1
            }
        } else {
            let denom = n - 1
            if (denom < 1) { denom = 1; }
            let pts = []
            let i = 0
            while (i < n) {
                let px = plotX + Math.round(i * 1.0 * plotW / denom)
                let py = plotY + plotH - Math.round((data[i] - ymin) * 1.0 * plotH / span)
                pts.push(px)
                pts.push(py)
                i = i + 1
            }
            // "area": polígono cerrado contra la baseline; "line": solo la polilínea.
            if (ctype == "area") {
                let poly = []
                let j = 0
                while (j < pts.length()) { poly.push(pts[j]); j = j + 1; }
                poly.push(plotX + plotW); poly.push(baseY)
                poly.push(plotX);         poly.push(baseY)
                this.swPolygon(poly, col)
            }
            if (n > 1) {
                this.swPolyline(pts, 2, col)
            } else {
                this.swCircle(pts[0], pts[1], 3, col)
            }
            if (node.getProp("dots") == true) {
                let d = 0
                while (d < pts.length()) {
                    this.swCircle(pts[d], pts[d + 1], 3, col)
                    d = d + 2
                }
            }
        }

        this.cy = this.cy + bh + 12
    }

    // ── DropZone (zona de arrastre-y-suelta de archivos) ───────────────────────
    // Se resalta cuando hay archivos arrastrándose sobre la ventana (filesHovering,
    // que window.sz fija desde Gui.hoveredFiles). El drop lo enruta el loop al onDrop.
    public void renderDropZone(any node) {
        let label = node.getProp("label")
        if (label == null) { label = "Arrastra archivos aqui"; }
        let bh = node.getProp("height")
        if (bh == null) { bh = 120; }

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth

        let hi = this.filesHovering
        let bc = this.colBorder
        let tc = this.colMuted
        if (hi) { bc = this.colFocus; tc = this.colText; }

        // Fondo + tinte de acento translúcido cuando hay arrastre encima.
        this.swRect(bx, by, bw, bh, this.colInput)
        if (hi) { this.swRectAlpha(bx, by, bw, bh, this.colFocus, 36); }
        // Borde punteado (más grueso al resaltar).
        this.dashedRect(bx, by, bw, bh, bc, hi)

        // Etiqueta centrada, en fuente PROPORCIONAL (mide y dibuja con la misma → centra bien).
        let scale = 2
        let dfam = this.setFam("body")
        let tw = Gui.measureText("" + label, scale)[0]
        let tx = bx + (bw - tw) / 2
        let ty = by + (bh - 8 * scale) / 2
        this.swText(tx, ty, "" + label, scale, tc)
        if (dfam) { this.swSetFont(""); }

        this.regions.push(["DropZone", bx, by, bw, bh, node])
        this.cy = this.cy + bh + 12
    }

    // Borde punteado alrededor de una caja (segmentos de dash con hueco). thick=2px.
    public void dashedRect(int x, int y, int w, int h, int col, bool thick) {
        let dash = 8
        let gap  = 6
        let t    = 1
        if (thick) { t = 2; }
        let px = x
        while (px < x + w) {
            let seg = dash
            if (px + seg > x + w) { seg = x + w - px; }
            this.swRect(px, y, seg, t, col)
            this.swRect(px, y + h - t, seg, t, col)
            px = px + dash + gap
        }
        let py = y
        while (py < y + h) {
            let seg = dash
            if (py + seg > y + h) { seg = y + h - py; }
            this.swRect(x, py, t, seg, col)
            this.swRect(x + w - t, py, t, seg, col)
            py = py + dash + gap
        }
    }

    // ── Dropdown (caja + overlay diferido) ─────────────────────────────────────
    public void renderDropdown(any node) {
        let value    = node.getProp("value")
        let disabled = node.getProp("disabled") == true

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        let bh = 34

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        this.fillBox("Dropdown", bx, by, bw, bh, this.colorFor("Dropdown", "background-color", this.colInput))
        let dfam = this.setFam("Dropdown")
        this.swText(bx + 10, by + 9, "" + value, 2, this.colorFor("Dropdown", "color", this.colText))
        if (dfam) { this.swSetFont(""); }
        this.drawTriDown(bx + bw - 16, by + 14, 4, this.colMuted)
        if (focused) { this.drawFocusRing(bx, by, bw, bh); }

        this.regions.push(["Dropdown", bx, by, bw, bh, node])

        if (focused && this.dropOpen) {
            this.hasOpenDrop  = true
            this.openDropX    = bx
            this.openDropY    = by
            this.openDropW    = bw
            this.openDropH    = bh
            this.openDropNode = node
        }
        this.cy = this.cy + bh + 12
    }

    // Overlay de opciones del dropdown abierto (dibujado al final, encima de todo).
    public void drawDropdownOverlay() {
        let node = this.openDropNode
        if (node == null) { return; }
        let opts = node.getProp("options")
        if (opts == null) { return; }

        let dx = this.openDropX
        let dw = this.openDropW
        let oy0 = this.openDropY + this.openDropH
        let optH = 30

        let ofam = this.setFam("Dropdown")
        let i = 0
        while (i < opts.length()) {
            let oy = oy0 + i * optH
            let bg = this.colInput
            if (i == this.dropHi) { bg = this.colBtnHov; }
            this.swRect(dx, oy, dw, optH, bg)
            this.swRect(dx, oy, dw, 1, this.colBorder)
            this.swText(dx + 10, oy + 9, "" + opts[i], 2, this.colText)
            i = i + 1
        }
        if (ofam) { this.swSetFont(""); }
        this.swRect(dx, oy0 + opts.length() * optH, dw, 2, this.colBorder)
    }

    // ── Label / Link ───────────────────────────────────────────────────────────
    public void renderLabel(any node) {
        this.drawWrapped("Label", this.collectText(node), 2, this.colorFor("Label", "color", this.colText), 8)
    }

    public void renderLink(any node) {
        let label    = this.collectText(node)
        let scale    = 2
        let fam      = this.setFam("Link")
        let m        = Gui.measureText(label, scale)
        let lw       = m[0]
        let bx       = this.cx
        let by       = this.cy
        let disabled = node.getProp("disabled") == true

        let myOrd  = this.focusOrd
        let focused = myOrd == this.focus && !disabled
        this.focusOrd = this.focusOrd + 1

        let col = this.colorFor("Link", "color", this.colLink)
        this.swText(bx, by, label, scale, col)
        if (fam) { this.swSetFont(""); }
        this.swRect(bx, by + 8 * scale + 1, lw, 1, col)
        if (focused) { this.drawFocusRing(bx, by, lw, 8 * scale + 4); }

        this.regions.push(["Link", bx, by, lw, 8 * scale + 4, node])
        this.lastW = lw
        this.cy = this.cy + 8 * scale + 12
    }

    // Ancho natural (px) de un nodo, para decidir el auto-wrap del Row. Los elásticos
    // (Input/Select/Textarea/Dropdown/Slider/ProgressBar/RadioGroup) y contenedores son
    // flexibles → devuelven 0 (no fuerzan el wrap; se encogen para compartir el ancho).
    public int measureNodeWidth(any node) {
        if (node == null) { return 0; }
        let isPrim = node is string || node is int || node is decimal || node is bool
        if (isPrim) { return this.measureFor("body", "" + node, 2); }
        let tag = node.getTag()
        if (tag == "Button") { return this.measureFor("Button", this.collectText(node), 2) + 28; }
        if (tag == "Link")   { return this.measureFor("Link", this.collectText(node), 2); }
        if (tag == "Label")  { return this.measureFor("Label", this.collectText(node), 2); }
        if (tag == "Checkbox") {
            let lbl = node.getProp("label")
            if (lbl == null) { lbl = this.collectText(node); }
            return 28 + Gui.measureText("" + lbl, 2)[0]
        }
        if (tag == "h1") { return this.measureFor("h1", this.collectText(node), this.numProp("h1", "font-scale", 3)); }
        if (tag == "h2") { return this.measureFor("h2", this.collectText(node), this.numProp("h2", "font-scale", 2)); }
        if (tag == "p" || tag == "span" || tag == "h3" || tag == "li") {
            return this.measureFor(tag, this.collectText(node), this.numProp(tag, "font-scale", 2))
        }
        return 0
    }

    // ── Row (flujo horizontal, ancho de contenido, alineado a la izquierda) ─────
    public void renderRow(any node) {
        // direction: column (responsive .szs) → apilar en vertical como un contenedor.
        if (this.strProp("Row", "direction", "row") == "column") {
            let kids = node.getChildren()
            let ki = 0
            while (ki < kids.length()) { this.renderNode(kids[ki]); ki = ki + 1 }
            return
        }
        let children = node.getChildren()
        let k = 0
        let i = 0
        while (i < children.length()) {
            if (children[i] != null) { k = k + 1; }
            i = i + 1
        }
        if (k == 0) { return; }

        let gap   = this.numProp("Row", "gap", 10)
        // Auto-wrap (Capa 3): si los hijos de ancho fijo no entran lado a lado, apilar en
        // vertical. `wrap={false}` lo desactiva. (`direction: column` del .szs ya forzó vertical.)
        if (node.getProp("wrap") != false) {
            let fixedSum = gap * (k - 1)
            let wi = 0
            while (wi < children.length()) {
                if (children[wi] != null) { fixedSum = fixedSum + this.measureNodeWidth(children[wi]); }
                wi = wi + 1
            }
            if (fixedSum > this.colWidth) {
                let ci = 0
                while (ci < children.length()) { this.renderNode(children[ci]); ci = ci + 1 }
                return
            }
        }
        // Reparto por pesos: cada hijo puede llevar `flex={n}` (default 1). El ancho
        // disponible se reparte proporcional a los pesos. Sin flex en ningún hijo →
        // reparto en partes iguales (idéntico al comportamiento anterior).
        let avail = this.colWidth - gap * (k - 1)
        let totalFlex = 0
        let fi = 0
        while (fi < children.length()) {
            if (children[fi] != null) {
                let fx = children[fi].getProp("flex")
                if (fx == null) { fx = 1; }
                totalFlex = totalFlex + fx
            }
            fi = fi + 1
        }
        if (totalFlex < 1) { totalFlex = 1; }

        let startX    = this.cx
        let startY    = this.cy
        let savedColW = this.colWidth
        let maxH = 0
        let xi   = startX

        i = 0
        while (i < children.length()) {
            let child = children[i]
            if (child != null) {
                let fx = child.getProp("flex")
                if (fx == null) { fx = 1; }
                let cellW = (avail * fx) / totalFlex
                this.cx       = xi
                this.cy       = startY
                this.colWidth = cellW
                this.lastW    = cellW    // default; los de ancho natural (Button, Checkbox…) lo achican
                this.renderNode(child)
                let hh = this.cy - startY
                if (hh > maxH) { maxH = hh; }
                xi = xi + this.lastW + gap
            }
            i = i + 1
        }

        this.colWidth = savedColW
        this.cx       = startX
        this.cy       = startY + maxH
    }

    // ── Sombra suave (alpha) ───────────────────────────────────────────────────
    public void softShadow(int x, int y, int w, int h) {
        this.swRectAlpha(x + 2, y + 4, w, h, 0x000000, 55)
        this.swRectAlpha(x + 1, y + 2, w, h, 0x000000, 35)
    }

    // ── Caché de imágenes (ruta → handle de Gui.loadImage) ─────────────────────
    public int imgHandle(string path) {
        let i = 0
        while (i < this.imgPaths.length()) {
            if (this.imgPaths[i] == path) { return this.imgHandles[i]; }
            i = i + 1
        }
        let hnd = -1
        try { hnd = Gui.loadImage(path); } catch (e) { hnd = -1; }
        this.imgPaths.push(path)
        this.imgHandles.push(hnd)
        return hnd
    }

    // Caché para imágenes EN MEMORIA (bytes, p.ej. fetcheadas): decodifica una sola
    // vez con Gui.loadImageBytes, llaveado por `key` (id estable — usar la URL/src).
    public int imgHandleBytes(string key, any bytes) {
        let i = 0
        while (i < this.imgPaths.length()) {
            if (this.imgPaths[i] == key) { return this.imgHandles[i]; }
            i = i + 1
        }
        let hnd = -1
        if (bytes != null) {
            if (bytes.length() > 0) {
                try { hnd = Gui.loadImageBytes(bytes); } catch (e) { hnd = -1; }
            }
        }
        this.imgPaths.push(key)
        this.imgHandles.push(hnd)
        return hnd
    }

    // ── Image (ruta o bytes; width/height escala; alpha opcional) ──────────────
    public void renderImage(any node) {
        let src   = node.getProp("src")
        let bytes = node.getProp("bytes")
        if (src == null && bytes == null) { return; }
        // `bytes` (imagen en memoria, p.ej. fetcheada) tiene prioridad; se cachea por
        // `src` como id estable (usar la URL). Sin `bytes`, `src` es una ruta de archivo.
        let hnd = -1
        if (bytes != null) {
            let key = "bytes:"
            if (src != null) { key = "bytes:" + src; }
            hnd = this.imgHandleBytes(key, bytes)
        } else {
            hnd = this.imgHandle("" + src)
        }
        if (hnd < 0) {
            let alt = node.getProp("alt")
            if (alt == null) { alt = "[image]"; }
            this.drawWrapped("", "" + alt, 2, this.colMuted, 6)
            return
        }
        let sz = Gui.imageSize(hnd)
        // width/height opcionales → escala (aspect ratio si solo se da uno); sin ellos,
        // tamaño nativo (como antes). alpha opcional (0–255) para imágenes semitransparentes.
        let pw = node.getProp("width")
        let ph = node.getProp("height")
        let dw = sz[0]
        let dh = sz[1]
        if (pw != null && ph != null) { dw = pw; dh = ph }
        else if (pw != null && sz[0] > 0) { dw = pw; dh = sz[1] * pw / sz[0] }
        else if (ph != null && sz[1] > 0) { dh = ph; dw = sz[0] * ph / sz[1] }
        if (dw != sz[0] || dh != sz[1]) {
            let al = node.getProp("alpha")
            if (al == null) { this.swImage(this.cx, this.cy, hnd, dw, dh) }
            else { this.swImage(this.cx, this.cy, hnd, dw, dh, al) }
        } else {
            this.swImage(this.cx, this.cy, hnd)
        }
        this.lastW = dw
        this.cy = this.cy + dh + 10
    }

    // ── Table (solo lectura: encabezados + filas, celdas alineadas) ────────────
    public void renderTable(any node) {
        let columns = node.getProp("columns")
        let rows    = node.getProp("rows")
        if (columns == null) { columns = []; }
        if (rows == null) { rows = []; }
        let ncol = columns.length()
        if (ncol == 0 && rows.length() > 0) { ncol = rows[0].length(); }
        if (ncol == 0) { return; }

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        let cellW = bw / ncol
        // Texto legible con fuente real (proporcional, hereda body); tamaño y alto
        // de fila desde font-scale (antes era scale 1 = 8px con la bitmap → ilegible).
        let scale = this.numProp("Table", "font-scale", 2)
        let fam   = this.setFam("Table")
        let rowH  = 8 * scale + 12
        let ty    = (rowH - 8 * scale) / 2
        if (ty < 2) { ty = 2; }

        let y = by
        if (columns.length() > 0) {
            this.swRect(bx, y, bw, rowH, this.colBtn)
            let c = 0
            while (c < ncol) {
                let label = ""
                if (c < columns.length()) { label = "" + columns[c]; }
                this.swText(bx + c * cellW + 8, y + ty, this.fitCell(label, cellW - 16, scale), scale, 0xffffff)
                c = c + 1
            }
            y = y + rowH
        }

        let r2 = 0
        while (r2 < rows.length()) {
            let bgc = this.colInput
            if (r2 % 2 == 1) { bgc = this.colBg; }
            this.swRect(bx, y, bw, rowH, bgc)
            let row = rows[r2]
            let c2 = 0
            while (c2 < ncol) {
                let cell = ""
                if (c2 < row.length()) { cell = "" + row[c2]; }
                this.swText(bx + c2 * cellW + 8, y + ty, this.fitCell(cell, cellW - 16, scale), scale, this.colText)
                c2 = c2 + 1
            }
            y = y + rowH
            r2 = r2 + 1
        }
        if (fam) { this.swSetFont(""); }
        this.swRectOutline(bx, by, bw, y - by, this.colBorder)
        this.lastW = bw
        this.cy = y + 12
    }

    // Recorta `text` (con la fuente activa) para que entre en `maxW` px.
    public string fitCell(string text, int maxW, int scale) {
        if (Gui.measureText(text, scale)[0] <= maxW) { return text; }
        let t = text
        while (t.length() > 1 && Gui.measureText(t + "…", scale)[0] > maxW) {
            t = t.substring(0, t.length() - 1)
        }
        return t + "…"
    }

    // ── Toast (banner transitorio; el auto-cierre lo maneja el componente) ─────
    public void renderToast(any node) {
        let msg = node.getProp("message")
        if (msg == null) { msg = this.collectText(node); }
        let kind = node.getProp("kind")
        if (kind == null) { kind = "info"; }
        let col = this.colBtn
        if (kind == "success") { col = 0x16a34a; }
        else if (kind == "warn") { col = 0xd97706; }
        else if (kind == "error") { col = 0xdc2626; }

        let bx = this.cx
        let by = this.cy
        let bw = this.colWidth
        let bh = 34
        this.softShadow(bx, by, bw, bh)
        this.swRoundRect(bx, by, bw, bh, 6, col)
        this.swText(bx + 12, by + 9, "" + msg, 2, 0xffffff)
        this.cy = this.cy + bh + 12
    }

    // ── Modal (diferido): solo marca; el overlay se pinta al final ─────────────
    public void renderModal(any node) {
        if (node.getProp("open") != true) { return; }
        this.hasModal  = true
        this.modalNode = node
    }

    public bool modalActive()     { return this.hasModal }
    public int  getModalRegStart() { return this.modalRegStart }
    public any  getModalNode()    { return this.modalNode }
    // ¿(mx,my) cae dentro de la caja del modal (no en el scrim de fondo)?
    public bool modalBoxContains(int mx, int my) {
        return mx >= this.modalBoxX && mx < this.modalBoxX + this.modalBoxW
        && my >= this.modalBoxY && my < this.modalBoxY + this.modalBoxH
    }

    // Scrim + caja centrada con los children del Modal (registra sus regiones a
    // partir de modalRegStart → handleGuiInput restringe la interacción al modal).
    public void drawModalOverlay() {
        let node = this.modalNode
        if (node == null) { return; }
        this.swRectAlpha(0, 0, this.w, this.h, 0x000000, 150)

        let mw = this.w * 3 / 4
        if (mw > 520) { mw = 520; }
        if (mw < 240) { mw = 240; }
        let mh = this.h * 3 / 5
        if (mh > 360) { mh = 360; }
        if (mh < 140) { mh = 140; }
        let mx = (this.w - mw) / 2
        let my = (this.h - mh) / 2
        this.modalBoxX = mx; this.modalBoxY = my; this.modalBoxW = mw; this.modalBoxH = mh
        this.softShadow(mx, my, mw, mh)
        this.swRoundRect(mx, my, mw, mh, 10, this.colInput)
        this.swRectOutline(mx, my, mw, mh, this.colBorder)

        let innerX = mx + 18
        let innerW = mw - 36
        let topY   = my + 16
        let title  = node.getProp("title")
        if (title != null) {
            this.swText(innerX, topY, "" + title, 2, this.colText)
            topY = topY + 28
            this.swRect(innerX, topY, innerW, 1, this.colBorder)
            topY = topY + 12
        }

        this.modalRegStart = this.regions.length()
        // Botón de cierre ✕ (arriba-derecha) si el Modal define onClose.
        if (node.getProp("onClose") != null) {
            let cs  = 26
            let cxb = mx + mw - cs - 8
            let cyb = my + 8
            let chov = this.mouseX >= cxb && this.mouseX < cxb + cs && this.mouseY >= cyb && this.mouseY < cyb + cs
            let ccol = this.colMuted
            if (chov) { ccol = this.colText; }
            this.swText(cxb + 8, cyb + 5, "x", 2, ccol)
            this.regions.push(["ModalClose", cxb, cyb, cs, cs, node])
        }
        let savedCx = this.cx
        let savedCy = this.cy
        let savedCW = this.colWidth
        this.swClipPush(mx, my, mw, mh)
        this.cx       = innerX
        this.cy       = topY
        this.colWidth = innerW
        let kids = node.getChildren()
        let i = 0
        while (i < kids.length()) {
            this.renderNode(kids[i])
            i = i + 1
        }
        this.swClipPop()
        this.cx       = savedCx
        this.cy       = savedCy
        this.colWidth = savedCW
    }

    // ── Tooltip (envoltorio): dibuja children; al hover difiere la cajita ──────
    public void renderTooltip(any node) {
        let startX = this.cx
        let startY = this.cy
        let kids = node.getChildren()
        let i = 0
        while (i < kids.length()) { this.renderNode(kids[i]); i = i + 1 }
        let endY = this.cy
        if (this.mouseX >= startX && this.mouseX < startX + this.colWidth && this.mouseY >= startY && this.mouseY < endY) {
            let tip = node.getProp("tip")
            if (tip != null) {
                this.hasTip  = true
                this.tipText = "" + tip
                this.tipX    = this.mouseX
                this.tipY    = this.mouseY
            }
        }
    }

    public void drawTooltipOverlay() {
        let tip = this.tipText
        let scale = 1
        let tw = Gui.measureText(tip, scale)[0] + 12
        let th = 20
        let tx = this.tipX + 12
        let ty = this.tipY + 18
        if (tx + tw > this.w) { tx = this.w - tw - 4; }
        if (ty + th > this.h) { ty = this.tipY - th - 4; }
        this.softShadow(tx, ty, tw, th)
        this.swRoundRect(tx, ty, tw, th, 4, 0x1f2937)
        this.swText(tx + 6, ty + 5, tip, scale, this.colText)
    }

    // Nombre de cursor para la posición del mouse (mano sobre interactivos, I-beam
    // sobre campos de texto). Recorre de arriba hacia abajo (overlays primero).
    public string cursorName(int mx, int my) {
        let i = this.regions.length() - 1
        while (i >= 0) {
            let rg = this.regions[i]
            if (mx >= rg[1] && mx < rg[1] + rg[3] && my >= rg[2] && my < rg[2] + rg[4]) {
                let tag = rg[0]
                if (tag == "Button" || tag == "Link" || tag == "Dropdown" || tag == "Select" || tag == "Checkbox" || tag == "Switch" || tag == "FileInput" || tag == "Tabs" || tag == "Collapsible") { return "hand"; }
                if (tag == "Textarea") {
                    let totalSegs = rg[7]
                    let visRows = rg[8]
                    if (totalSegs > visRows && mx >= rg[1] + rg[3] - 24) {
                        return "default"
                    }
                    return "text"
                }
                if (tag == "Input") { return "text"; }
                return "default"
            }
            i = i - 1
        }
        return "default"
    }

    public string collectText(any node) {
        if (node == null)    { return ""; }
        if (node is string)  { return node; }
        if (node is int)     { return "" + node; }
        if (node is decimal) { return "" + node; }
        if (node is bool)    { return "" + node; }

        let text     = ""
        let children = node.getChildren()
        let i        = 0
        while (i < children.length()) {
            text = text + this.collectText(children[i])
            i = i + 1
        }
        return text
    }
}
