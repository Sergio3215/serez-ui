// Separator — horizontal rule
//
// let sep = new Separator()
// sep.char = "─"      // single char repeated across width (default ─)
// sep.render(width) → ["─────...─"]

export public class Separator {
    public Separator() {
        this.char = "─"
    }

    public render(width) {
        return [repeatStr(this.char, width)]
    }
}
