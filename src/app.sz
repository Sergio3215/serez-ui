// App — top-level renderer
//
// let app = new App()
// app.width = 60           // canvas width in chars (default 60)
// app.render(root_widget)  // renders widget tree to stdout

export public class App {
    public App() {
        this.width = 60
    }

    public render(root) {
        let lines = root.render(this.width)
        let i = 0
        while (i < lines.length()) {
            out lines[i]
            i = i + 1
        }
    }
}
