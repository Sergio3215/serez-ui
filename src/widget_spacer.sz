// Spacer — blank vertical space
//
// let sp = new Spacer(2)   // 2 blank lines
// sp.render(width) → ["   ", "   "]

export public class Spacer {
    public Spacer(int height) {
        this.height = height
    }

    public render(width) {
        let lines = []
        let i = 0
        while (i < this.height) {
            lines.push(repeatStr(" ", width))
            i = i + 1
        }
        return lines
    }
}
